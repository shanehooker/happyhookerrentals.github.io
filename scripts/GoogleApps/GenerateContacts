function onEdit(e) {
  try {
    if (!e || !e.range) return;

    const editedRange = e.range;
    const editedSheet = editedRange.getSheet();
    if (!editedSheet || editedSheet.getName() !== CONTACTS_MASTER_SHEET_NAME) return;

    const selectAllRange = getContactsSelectAllRange_();
    if (!selectAllRange) return;
    if (editedRange.getSheet().getSheetId() !== selectAllRange.getSheet().getSheetId()) return;
    if (editedRange.getA1Notation() !== selectAllRange.getA1Notation()) return;

    toggleAllContactSelections_(editedSheet, e.value === "TRUE");
  } catch (err) {
    Logger.log("GenerateContacts onEdit error: " + err);
  }
}

function ImportCustomerListToContacts() {
  const statusLog = [];

  try {
    const spreadsheet = SpreadsheetApp.openById(CONTACTS_DESTINATION_SPREADSHEET_ID);
    const customerListSheet = spreadsheet.getSheetByName(CUSTOMER_LIST_SHEET_NAME);
    const contactsSheet = spreadsheet.getSheetByName(CONTACTS_MASTER_SHEET_NAME);

    if (!customerListSheet) {
      throw new Error(`Sheet '${CUSTOMER_LIST_SHEET_NAME}' not found.`);
    }
    if (!contactsSheet) {
      throw new Error(`Sheet '${CONTACTS_MASTER_SHEET_NAME}' not found.`);
    }

    const customerHeaders = customerListSheet.getRange(1, 1, 1, customerListSheet.getLastColumn()).getDisplayValues()[0];
    const customerNameCol = findHeaderColumnInRow_(customerHeaders, CONTACTS_NAME_HEADERS);
    const customerPhoneCol = findHeaderColumnInRow_(customerHeaders, CONTACTS_PHONE_HEADERS);
    const customerEmailCol = findHeaderColumnInRow_(customerHeaders, CONTACTS_EMAIL_HEADERS);
    const customerNotesCol = findHeaderColumnInRow_(customerHeaders, CONTACTS_NOTES_HEADERS);

    if (!customerNameCol || !customerPhoneCol || !customerEmailCol || !customerNotesCol) {
      throw new Error(
        `Sheet '${CUSTOMER_LIST_SHEET_NAME}' must contain Renter Name, Renter Phone, Renter Email, and Notes columns.`
      );
    }

    const contactsHeaders = contactsSheet.getRange(CONTACTS_HEADER_ROW, 1, 1, contactsSheet.getLastColumn()).getDisplayValues()[0];
    const contactsNameCol = findHeaderColumnInRow_(contactsHeaders, ["Renter Name"]);
    if (!contactsNameCol) {
      throw new Error(`Sheet '${CONTACTS_MASTER_SHEET_NAME}' must contain a 'Renter Name' column.`);
    }

    const nextCell = findExactCell_(contactsSheet, "{{next}}");
    if (!nextCell) {
      throw new Error(`Cannot find {{next}} placeholder in '${CONTACTS_MASTER_SHEET_NAME}'.`);
    }

    const customerLastRow = customerListSheet.getLastRow();
    if (customerLastRow <= 1) {
      addGenerateContactsStatus_(statusLog, "CustomerList import", true, `No data rows found in '${CUSTOMER_LIST_SHEET_NAME}'.`);
      showGenerateContactsStatus_("CustomerList Import Status", statusLog);
      return;
    }

    const customerRows = customerListSheet.getRange(2, 1, customerLastRow - 1, customerListSheet.getLastColumn()).getDisplayValues();
    let insertedCount = 0;
    let existingCount = 0;
    let skippedCount = 0;

    customerRows.forEach((rowValues, index) => {
      const renterName = String(rowValues[customerNameCol - 1] || "").trim();
      const renterPhone = String(rowValues[customerPhoneCol - 1] || "").trim();
      const renterEmail = String(rowValues[customerEmailCol - 1] || "").trim();
      const notes = String(rowValues[customerNotesCol - 1] || "").trim();

      if (!renterName) {
        skippedCount++;
        return;
      }

      const existingRow = findExistingContactsSheetRowByName_(contactsSheet, CONTACTS_HEADER_ROW, renterName);
      if (existingRow) {
        existingCount++;
        return;
      }

      const insertedRow = insertContactsSheetRow_(contactsSheet, contactsHeaders, renterName, renterPhone, renterEmail, notes);
      insertedCount++;
      addGenerateContactsStatus_(
        statusLog,
        "CustomerList row",
        true,
        `Inserted '${renterName}' into '${CONTACTS_MASTER_SHEET_NAME}' row ${insertedRow} from '${CUSTOMER_LIST_SHEET_NAME}' row ${index + 2}.`
      );
    });

    addGenerateContactsStatus_(
      statusLog,
      "CustomerList import",
      true,
      `Inserted ${insertedCount}, already existed ${existingCount}, skipped ${skippedCount}.`
    );
  } catch (e) {
    addGenerateContactsStatus_(statusLog, "CustomerList import", false, e.toString());
  }

  showGenerateContactsStatus_("CustomerList Import Status", statusLog);
}

function ImportGoogleContactsToContacts() {
  const statusLog = [];

  try {
    const spreadsheet = SpreadsheetApp.openById(CONTACTS_DESTINATION_SPREADSHEET_ID);
    const sourceSheet = spreadsheet.getSheetByName(GOOGLE_CONTACTS_SOURCE_SHEET_NAME);
    const contactsSheet = spreadsheet.getSheetByName(CONTACTS_MASTER_SHEET_NAME);

    if (!sourceSheet) {
      throw new Error(`Sheet '${GOOGLE_CONTACTS_SOURCE_SHEET_NAME}' not found.`);
    }
    if (!contactsSheet) {
      throw new Error(`Sheet '${CONTACTS_MASTER_SHEET_NAME}' not found.`);
    }

    const sourceHeaders = sourceSheet.getRange(1, 1, 1, sourceSheet.getLastColumn()).getDisplayValues()[0];
    const firstNameCol = findHeaderColumnInRow_(sourceHeaders, GOOGLE_CONTACTS_FIRST_NAME_HEADERS);
    const lastNameCol = findHeaderColumnInRow_(sourceHeaders, GOOGLE_CONTACTS_LAST_NAME_HEADERS);
    const emailCol = findHeaderColumnInRow_(sourceHeaders, GOOGLE_CONTACTS_EMAIL_HEADERS);
    const phoneCol = findHeaderColumnInRow_(sourceHeaders, GOOGLE_CONTACTS_PHONE_HEADERS);

    if (!firstNameCol && !lastNameCol) {
      throw new Error(`Sheet '${GOOGLE_CONTACTS_SOURCE_SHEET_NAME}' must contain First Name and/or Last Name columns.`);
    }
    if (!emailCol) {
      throw new Error(`Sheet '${GOOGLE_CONTACTS_SOURCE_SHEET_NAME}' must contain 'E-mail 1 - Value'.`);
    }

    const contactsHeaders = contactsSheet.getRange(CONTACTS_HEADER_ROW, 1, 1, contactsSheet.getLastColumn()).getDisplayValues()[0];
    const sourceLastRow = sourceSheet.getLastRow();
    if (sourceLastRow <= 1) {
      addGenerateContactsStatus_(statusLog, "Google Contacts import", true, `No data rows found in '${GOOGLE_CONTACTS_SOURCE_SHEET_NAME}'.`);
      showGenerateContactsStatus_("Google Contacts Import Status", statusLog);
      return;
    }

    const sourceRows = sourceSheet.getRange(2, 1, sourceLastRow - 1, sourceSheet.getLastColumn()).getDisplayValues();
    let insertedCount = 0;
    let existingCount = 0;
    let skippedCount = 0;

    sourceRows.forEach((rowValues, index) => {
      const firstName = String(firstNameCol ? rowValues[firstNameCol - 1] || "" : "").trim();
      const lastName = String(lastNameCol ? rowValues[lastNameCol - 1] || "" : "").trim();
      const renterName = [firstName, lastName].filter(Boolean).join(" ").trim();
      const renterEmail = String(rowValues[emailCol - 1] || "").trim();
      const renterPhone = String(phoneCol ? rowValues[phoneCol - 1] || "" : "").trim();

      if (!renterName) {
        skippedCount++;
        return;
      }

      const existingRow = findExistingContactsSheetRowByName_(contactsSheet, CONTACTS_HEADER_ROW, renterName);
      if (existingRow) {
        existingCount++;
        return;
      }

      const insertedRow = insertContactsSheetRow_(contactsSheet, contactsHeaders, renterName, renterPhone, renterEmail, "");
      insertedCount++;
      addGenerateContactsStatus_(
        statusLog,
        "Google Contacts row",
        true,
        `Inserted '${renterName}' into '${CONTACTS_MASTER_SHEET_NAME}' row ${insertedRow} from '${GOOGLE_CONTACTS_SOURCE_SHEET_NAME}' row ${index + 2}.`
      );
    });

    addGenerateContactsStatus_(
      statusLog,
      "Google Contacts import",
      true,
      `Inserted ${insertedCount}, already existed ${existingCount}, skipped ${skippedCount}.`
    );
  } catch (e) {
    addGenerateContactsStatus_(statusLog, "Google Contacts import", false, e.toString());
  }

  showGenerateContactsStatus_("Google Contacts Import Status", statusLog);
}

function collectContactsFromBookingFolder_(statusLog) {
  const folder = DriveApp.getFolderById(CONTACTS_BOOKING_FOLDER_ID);
  const files = folder.getFiles();
  const contacts = [];
  let scannedFiles = 0;
  let matchedFiles = 0;

  while (files.hasNext()) {
    const file = files.next();
    scannedFiles++;

    if (!/^HHRentals/i.test(file.getName())) continue;
    if (file.getMimeType() !== MimeType.GOOGLE_SHEETS) continue;

    matchedFiles++;

    try {
      const spreadsheet = SpreadsheetApp.openById(file.getId());
      const bookingsSheet = spreadsheet.getSheetByName(CONTACTS_BOOKINGS_SHEET_NAME);

      if (!bookingsSheet) {
        addGenerateContactsStatus_(statusLog, "Bookings scan", false, `Skipped '${file.getName()}': no '${CONTACTS_BOOKINGS_SHEET_NAME}' tab.`);
        continue;
      }

      const fileContacts = extractContactsFromBookingsSheet_(bookingsSheet, file.getName());
      contacts.push.apply(contacts, fileContacts);
      addGenerateContactsStatus_(statusLog, "Bookings scan", true, `Found ${fileContacts.length} contact(s) in '${file.getName()}'.`);
    } catch (e) {
      addGenerateContactsStatus_(statusLog, "Bookings scan", false, `Failed '${file.getName()}': ${e}`);
    }
  }

  addGenerateContactsStatus_(statusLog, "Bookings folder", true, `Scanned ${scannedFiles} file(s); matched ${matchedFiles} HHRentals sheet(s).`);
  return contacts;
}

