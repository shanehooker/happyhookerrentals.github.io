function collectHistoricalFinancialRows_(statusLog) {
  const folder = DriveApp.getFolderById(CONTACTS_BOOKING_FOLDER_ID);
  const files = folder.getFiles();
  const rowsByYear = {};
  let scannedFiles = 0;
  let matchedFiles = 0;

  while (files.hasNext()) {
    const file = files.next();
    scannedFiles++;

    if (!/^HHRentals/i.test(file.getName())) continue;
    if (file.getMimeType() !== MimeType.GOOGLE_SHEETS) continue;

    const year = extractHistoricalYearFromName_(file.getName());
    if (!year || year > 2025) continue;

    matchedFiles++;

    try {
      const spreadsheet = SpreadsheetApp.openById(file.getId());
      const reportRow = extractHistoricalFinancialRow_(spreadsheet, file.getName(), year);
      const existingRow = rowsByYear[year];

      if (!existingRow || getHistoricalFinancialRowScore_(reportRow) > getHistoricalFinancialRowScore_(existingRow)) {
        rowsByYear[year] = reportRow;
      }

      addGenerateContactsStatus_(
        statusLog,
        "Historical scan",
        true,
        `Scanned '${file.getName()}' for ${year}; found ${reportRow.foundCount} of ${HISTORICAL_FINANCIAL_FIELD_DEFS.length} fields.`
      );
    } catch (e) {
      addGenerateContactsStatus_(statusLog, "Historical scan", false, `Failed '${file.getName()}': ${e}`);
    }
  }

  addGenerateContactsStatus_(statusLog, "Historical files", true, `Scanned ${scannedFiles} file(s); matched ${matchedFiles} historical HHRentals sheet(s).`);

  return Object.keys(rowsByYear)
    .map(year => rowsByYear[year])
    .sort((a, b) => Number(a.year) - Number(b.year));
}

function extractHistoricalYearFromName_(fileName) {
  const matches = String(fileName || "").match(/\b(20\d{2})\b/g);
  if (!matches || !matches.length) return 0;

  const years = matches
    .map(value => Number(value))
    .filter(value => !isNaN(value));

  if (!years.length) return 0;
  return Math.max.apply(null, years);
}

function extractHistoricalFinancialRow_(spreadsheet, spreadsheetName, year) {
  const row = {
    year: year,
    spreadsheetName: spreadsheetName,
    actualIncome: "not found",
    expenses: "not found",
    grossProfit: "not found",
    taxReportedIncome: "not found",
    taxReportedExpenses: "not found",
    sourceNotes: [],
    foundCount: 0,
    score: 0
  };

  const candidateSheets = getHistoricalCandidateSheets_(spreadsheet);

  HISTORICAL_FINANCIAL_FIELD_DEFS.forEach(fieldDef => {
    const directMatch = findHistoricalFieldValue_(candidateSheets, fieldDef.aliases, false);
    const fallbackMatch = directMatch ? null : findHistoricalFieldValue_(candidateSheets, fieldDef.fallbackAliases, true);
    const match = directMatch || fallbackMatch;

    if (!match) return;

    row[fieldDef.key] = match.value;
    row.sourceNotes.push(`${fieldDef.label}: ${match.source}`);
    row.foundCount++;
    row.score += match.score;
  });

  if (!row.sourceNotes.length) {
    row.sourceNotes.push("No matching summary values found.");
  }

  return row;
}

function getHistoricalCandidateSheets_(spreadsheet) {
  const sheets = spreadsheet.getSheets();

  return sheets.sort((a, b) => {
    const aName = String(a.getName() || "").toLowerCase();
    const bName = String(b.getName() || "").toLowerCase();
    const aPriority = aName === "summary" ? 0 : (aName.indexOf("summary") !== -1 ? 1 : 2);
    const bPriority = bName === "summary" ? 0 : (bName.indexOf("summary") !== -1 ? 1 : 2);

    if (aPriority !== bPriority) return aPriority - bPriority;
    return aName.localeCompare(bName);
  });
}

function findHistoricalFieldValue_(candidateSheets, aliases, isFallback) {
  if (!aliases || !aliases.length) return null;

  let bestMatch = null;

  candidateSheets.forEach(sheet => {
    const values = sheet.getDataRange().getDisplayValues();
    const match = findHistoricalFieldValueInSheet_(sheet, values, aliases, isFallback);

    if (!match) return;
    if (!bestMatch || match.score > bestMatch.score) {
      bestMatch = match;
    }
  });

  return bestMatch;
}

function findHistoricalFieldValueInSheet_(sheet, values, aliases, isFallback) {
  if (!values.length || !values[0].length) return null;

  const normalizedAliases = aliases.map(normalizeHistoricalLabel_);
  let bestMatch = null;

  for (let row = 0; row < values.length; row++) {
    for (let col = 0; col < values[row].length; col++) {
      const cellText = String(values[row][col] || "").trim();
      if (!cellText) continue;

      const normalizedCell = normalizeHistoricalLabel_(cellText);
      if (!normalizedCell) continue;

      for (let i = 0; i < normalizedAliases.length; i++) {
        const alias = normalizedAliases[i];
        const matchType = getHistoricalLabelMatchType_(normalizedCell, alias);
        if (!matchType) continue;

        const extractedValue = extractHistoricalValueNearCell_(values, row, col);
        if (!extractedValue) continue;

        const score = scoreHistoricalMatch_(sheet, extractedValue, matchType, isFallback);
        const source = `${sheet.getName()}!${toA1Notation_(row + 1, col + 1)}`;
        const note = isFallback ? `${source} (fallback match '${aliases[i]}')` : `${source} ('${aliases[i]}')`;

        if (!bestMatch || score > bestMatch.score) {
          bestMatch = {
            value: extractedValue,
            score: score,
            source: note
          };
        }
      }
    }
  }

  return bestMatch;
}

function getHistoricalLabelMatchType_(normalizedCell, normalizedAlias) {
  if (!normalizedCell || !normalizedAlias) return "";
  if (normalizedCell === normalizedAlias) return "exact";
  if (normalizedCell.indexOf(normalizedAlias) !== -1) return "contains";
  return "";
}

function extractHistoricalValueNearCell_(values, row, col) {
  const inlineValue = extractInlineHistoricalValue_(values[row][col]);
  if (inlineValue) return inlineValue;

  for (let offset = 1; offset <= 3; offset++) {
    const rightValue = getHistoricalCellDisplayValue_(values, row, col + offset);
    if (isLikelyHistoricalValue_(rightValue)) return rightValue;
  }

  for (let offset = 1; offset <= 3; offset++) {
    const belowValue = getHistoricalCellDisplayValue_(values, row + offset, col);
    if (isLikelyHistoricalValue_(belowValue)) return belowValue;
  }

  for (let rowOffset = 1; rowOffset <= 2; rowOffset++) {
    for (let colOffset = 1; colOffset <= 2; colOffset++) {
      const diagonalValue = getHistoricalCellDisplayValue_(values, row + rowOffset, col + colOffset);
      if (isLikelyHistoricalValue_(diagonalValue)) return diagonalValue;
    }
  }

  return "";
}

function extractInlineHistoricalValue_(value) {
  const text = String(value || "").trim();
  if (!text) return "";

  const colonMatch = text.match(/:\s*([^\s].+)$/);
  if (colonMatch && isLikelyHistoricalValue_(colonMatch[1])) {
    return String(colonMatch[1]).trim();
  }

  return "";
}

function getHistoricalCellDisplayValue_(values, row, col) {
  if (row < 0 || col < 0) return "";
  if (row >= values.length) return "";
  if (col >= values[row].length) return "";
  return String(values[row][col] || "").trim();
}

function isLikelyHistoricalValue_(value) {
  const text = String(value || "").trim();
  if (!text) return false;
  if (/^(actual income|expenses|gross profit|tax reported income|tax reported expenses)$/i.test(text)) return false;
  return /[$(]?\s*-?\$?\d[\d,]*(?:\.\d{2})?\s*\)?$/.test(text) || /^-?\d[\d,]*(?:\.\d{2})?$/.test(text);
}

function normalizeHistoricalLabel_(value) {
  return String(value || "")
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function scoreHistoricalMatch_(sheet, value, matchType, isFallback) {
  let score = 0;

  if (matchType === "exact") score += 100;
  if (matchType === "contains") score += 70;
  if (!isFallback) score += 25;
  if (isLikelyHistoricalValue_(value)) score += 20;

  const sheetName = String(sheet.getName() || "").toLowerCase();
  if (sheetName === "summary") score += 30;
  else if (sheetName.indexOf("summary") !== -1) score += 20;
  else if (sheetName.indexOf("tax") !== -1 || sheetName.indexOf("income") !== -1 || sheetName.indexOf("profit") !== -1) score += 10;

  return score;
}

function getHistoricalFinancialRowScore_(row) {
  return Number(row && row.score || 0);
}

function writeHistoricalFinancialReportSheet_(rows, statusLog) {
  const destination = getContactsSpreadsheet_();
  const existingSheet = destination.getSheetByName(HISTORICAL_FINANCIAL_REPORT_SHEET_NAME);

  if (existingSheet) {
    destination.deleteSheet(existingSheet);
    addGenerateContactsStatus_(statusLog, "Historical output", true, `Replaced existing '${HISTORICAL_FINANCIAL_REPORT_SHEET_NAME}' tab.`);
  }

  const sheet = destination.insertSheet(HISTORICAL_FINANCIAL_REPORT_SHEET_NAME);
  const headers = [[
    "Year",
    "Spreadsheet",
    "Actual Income",
    "Expenses",
    "Gross Profit",
    "Tax Reported Income",
    "Tax Reported Expenses",
    "Source Notes"
  ]];

  sheet.getRange(1, 1, 1, headers[0].length).setValues(headers);
  sheet.getRange(1, 1, 1, headers[0].length).setFontWeight("bold");

  if (rows.length) {
    const outputRows = rows.map(row => [
      row.year,
      row.spreadsheetName,
      row.actualIncome,
      row.expenses,
      row.grossProfit,
      row.taxReportedIncome,
      row.taxReportedExpenses,
      row.sourceNotes.join("\n")
    ]);

    sheet.getRange(2, 1, outputRows.length, outputRows[0].length).setValues(outputRows);
    sheet.getRange(2, 8, outputRows.length, 1).setWrap(true);
  }

  sheet.setFrozenRows(1);
  sheet.autoResizeColumns(1, headers[0].length);
  return HISTORICAL_FINANCIAL_REPORT_SHEET_NAME;
}

function toA1Notation_(row, col) {
  let columnNumber = col;
  let letters = "";

  while (columnNumber > 0) {
    const remainder = (columnNumber - 1) % 26;
    letters = String.fromCharCode(65 + remainder) + letters;
    columnNumber = Math.floor((columnNumber - 1) / 26);
  }

  return `${letters}${row}`;
}

function extractContactsFromBookingsSheet_(sheet, sourceFileName) {
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 1 || lastCol < 1) return [];

  const scanRows = Math.min(lastRow, CONTACTS_BOOKINGS_HEADER_SCAN_ROWS);
  const scannedValues = sheet.getRange(1, 1, scanRows, lastCol).getDisplayValues();

  let headerRow = 0;
  let nameCol = 0;
  let phoneCol = 0;
  let emailCol = 0;

  scannedValues.some((rowValues, index) => {
    const testNameCol = findHeaderColumnInRow_(rowValues, CONTACTS_NAME_HEADERS);
    const testPhoneCol = findHeaderColumnInRow_(rowValues, CONTACTS_PHONE_HEADERS);
    const testEmailCol = findHeaderColumnInRow_(rowValues, CONTACTS_EMAIL_HEADERS);

    if (testNameCol && testPhoneCol && testEmailCol) {
      headerRow = index + 1;
      nameCol = testNameCol;
      phoneCol = testPhoneCol;
      emailCol = testEmailCol;
      return true;
    }

    return false;
  });

  if (!headerRow || lastRow <= headerRow) return [];

  const rows = sheet.getRange(headerRow + 1, 1, lastRow - headerRow, lastCol).getDisplayValues();
  const contacts = [];

  rows.forEach((rowValues, index) => {
    const renterName = String(rowValues[nameCol - 1] || "").trim();
    const renterPhone = String(rowValues[phoneCol - 1] || "").trim();
    const renterEmail = String(rowValues[emailCol - 1] || "").trim();

    if (!renterName || !renterPhone || !renterEmail) return;

    contacts.push({
      renterName,
      renterPhone,
      renterEmail,
      sourceType: "Bookings",
      sourceFileName,
      sourceSheetName: sheet.getName(),
      sourceRow: headerRow + 1 + index
    });
  });

  return contacts;
}

function collectContactsFromAgreementFolders_(statusLog) {
  const rootFolder = DriveApp.getFolderById(CONTACTS_AGREEMENT_ROOT_FOLDER_ID);
  const contacts = [];
  const stats = {
    folders: 0,
    agreementFiles: 0
  };

  collectContactsFromFolderRecursive_(rootFolder, contacts, statusLog, stats);
  addGenerateContactsStatus_(statusLog, "Agreement folders", true, `Scanned ${stats.folders} folder(s) and ${stats.agreementFiles} rental agreement file(s).`);
  return contacts;
}

function collectContactsFromFolderRecursive_(folder, contacts, statusLog, stats) {
  stats.folders++;

  const files = folder.getFiles();
  while (files.hasNext()) {
    const file = files.next();
    if (!/RentalAgreement/i.test(file.getName())) continue;

    stats.agreementFiles++;

    if (/template/i.test(file.getName())) {
      addGenerateContactsStatus_(statusLog, "Agreement scan", true, `Skipped template '${file.getName()}'.`);
      continue;
    }

    if (file.getMimeType() !== MimeType.GOOGLE_DOCS) {
      addGenerateContactsStatus_(statusLog, "Agreement scan", true, `Skipped non-Google-Doc '${file.getName()}'.`);
      continue;
    }

    try {
      const contact = extractContactFromAgreementFile_(file, folder.getName());
      if (contact) {
        contacts.push(contact);
        addGenerateContactsStatus_(statusLog, "Agreement scan", true, `Found contact in '${file.getName()}'.`);
      } else {
        addGenerateContactsStatus_(statusLog, "Agreement scan", false, `Skipped '${file.getName()}': missing renter name, phone, or email.`);
      }
    } catch (e) {
      addGenerateContactsStatus_(statusLog, "Agreement scan", false, `Failed '${file.getName()}': ${e}`);
    }
  }

  const subfolders = folder.getFolders();
  while (subfolders.hasNext()) {
    collectContactsFromFolderRecursive_(subfolders.next(), contacts, statusLog, stats);
  }
}

function extractContactFromAgreementFile_(file, sourceFolderName) {
  const fields = extractAgreementFieldsFromDocFile_(file);
  const agreementText = getAgreementDocText_(file);
  const patternMatches = extractContactPatternsFromText_(agreementText);

  const renterName =
    getAgreementFieldValue_(fields, CONTACTS_NAME_HEADERS.concat(["RenterName", "Name"])) ||
    patternMatches.renterName;
  const renterPhone =
    getAgreementFieldValue_(fields, CONTACTS_PHONE_HEADERS.concat(["RenterPhone", "Phone Number"])) ||
    patternMatches.renterPhone;
  const renterEmail =
    getAgreementFieldValue_(fields, CONTACTS_EMAIL_HEADERS.concat(["RenterEmail", "Email Address"])) ||
    patternMatches.renterEmail;

  if (!renterName || !renterPhone || !renterEmail) return null;

  return {
    renterName,
    renterPhone,
    renterEmail,
    sourceType: "RentalAgreement",
    sourceFileName: file.getName(),
    sourceSheetName: sourceFolderName,
    sourceRow: ""
  };
}

function extractAgreementFieldsFromDocFile_(docFile) {
  const doc = DocumentApp.openById(docFile.getId());
  const body = doc.getBody();
  const fields = {};

  function saveField(label, value) {
    const cleanLabel = normalizeAgreementFieldKey_(label);
    const cleanValue = String(value || "").trim();
    if (!cleanLabel || !cleanValue) return;
    fields[cleanLabel] = cleanValue;
  }

  const tables = body.getTables();
  tables.forEach(table => {
    for (let r = 0; r < table.getNumRows(); r++) {
      const row = table.getRow(r);
      const cellTexts = [];

      for (let c = 0; c < row.getNumCells(); c++) {
        cellTexts.push(row.getCell(c).getText().trim());
      }

      if (cellTexts.length >= 2 && cellTexts[0]) {
        const value = cellTexts.slice(1).find(text => text !== "");
        if (value) saveField(cellTexts[0], value);
      }

      for (let c = 0; c < cellTexts.length - 1; c++) {
        const label = cellTexts[c];
        if (!label) continue;
        const value = cellTexts.slice(c + 1).find(text => text !== "");
        if (value) saveField(label, value);
      }
    }
  });

  const lines = body.getText().split(/\r?\n/).map(line => line.trim()).filter(Boolean);
  lines.forEach((line, index) => {
    const inlineMatch = line.match(/^(.+?)\s*:\s*(.+)$/);
    if (inlineMatch) {
      saveField(inlineMatch[1], inlineMatch[2]);
      return;
    }

    const labelOnlyMatch = line.match(/^(.+?)\s*:\s*$/);
    if (labelOnlyMatch && lines[index + 1]) {
      saveField(labelOnlyMatch[1], lines[index + 1]);
    }
  });

  return fields;
}

function getAgreementDocText_(docFile) {
  const doc = DocumentApp.openById(docFile.getId());
  return doc.getBody().getText();
}

function extractContactPatternsFromText_(text) {
  const normalizedText = String(text || "").replace(/\r/g, "\n");
  const lines = normalizedText
    .split(/\n+/)
    .map(line => String(line || "").trim())
    .filter(Boolean);

  const emailMatch = normalizedText.match(/\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b/i);
  const phoneMatch = normalizedText.match(/\b\d{3}-\d{3}-\d{4}\b/);

  const renterName = extractRenterNameFromContextLines_(lines, emailMatch, phoneMatch);

  return {
    renterName: renterName,
    renterPhone: phoneMatch ? phoneMatch[0] : "",
    renterEmail: emailMatch ? emailMatch[0] : ""
  };
}

function extractRenterNameFromContextLines_(lines, emailMatch, phoneMatch) {
  const contextLines = [];
  const seenLines = {};

  for (let i = 0; i < lines.length; i++) {
    const lowerLine = String(lines[i] || "").toLowerCase();
    if (/(renter|guest|customer|lessee|name)/.test(lowerLine)) {
      addContextLine_(contextLines, seenLines, lines[i]);
      if (lines[i + 1]) addContextLine_(contextLines, seenLines, lines[i + 1]);
    }
  }

  addLinesNearMatch_(lines, emailMatch, contextLines, seenLines);
  addLinesNearMatch_(lines, phoneMatch, contextLines, seenLines);

  return findFirstLikelyPersonName_(contextLines);
}

function addLinesNearMatch_(lines, match, contextLines, seenLines) {
  if (!match || !match[0]) return;

  for (let i = 0; i < lines.length; i++) {
    if (String(lines[i] || "").indexOf(match[0]) === -1) continue;

    if (lines[i - 1]) addContextLine_(contextLines, seenLines, lines[i - 1]);
    addContextLine_(contextLines, seenLines, lines[i]);
    if (lines[i + 1]) addContextLine_(contextLines, seenLines, lines[i + 1]);
  }
}

function addContextLine_(contextLines, seenLines, line) {
  const cleanLine = String(line || "").trim();
  if (!cleanLine || seenLines[cleanLine]) return;

  seenLines[cleanLine] = true;
  contextLines.push(cleanLine);
}

function findFirstLikelyPersonName_(lines) {
  const nameRegex = /\b([A-Z][a-z]+(?:[-'][A-Z][a-z]+)? [A-Z][a-z]+(?:[-'][A-Z][a-z]+)?)\b/g;
  const excludedNames = {
    "Happy Hooker": true,
    "Rental Agreement": true,
    "Happy Campers": true,
    "Coachmen Clipper": true,
    "Glen Ellis": true
  };

  for (let i = 0; i < lines.length; i++) {
    const line = String(lines[i] || "");
    let match;

    while ((match = nameRegex.exec(line)) !== null) {
      const candidate = String(match[1] || "").trim();
      if (!candidate || excludedNames[candidate]) continue;
      return candidate;
    }
  }

  return "";
}

function getAgreementFieldValue_(fields, possibleNames) {
  for (let i = 0; i < possibleNames.length; i++) {
    const key = normalizeAgreementFieldKey_(possibleNames[i]);
    if (fields[key]) return fields[key];
  }

  return "";
}

function normalizeAgreementFieldKey_(key) {
  return String(key || "")
    .replace(/[:]/g, "")
    .replace(/\s+/g, "")
    .toLowerCase()
    .trim();
}

function addContactsToMap_(contactMap, contacts) {
  contacts.forEach(contact => {
    const key = buildContactKey_(contact);
    if (!key) return;

    if (!contactMap[key]) {
      contactMap[key] = {
        renterName: contact.renterName,
        renterPhone: contact.renterPhone,
        renterEmail: contact.renterEmail,
        sourceTypes: [contact.sourceType],
        sourceFiles: [contact.sourceFileName],
        sourceLocations: [contact.sourceSheetName],
        sourceRows: [contact.sourceRow]
      };
      return;
    }

    const existing = contactMap[key];
    existing.renterName = existing.renterName || contact.renterName;
    existing.renterPhone = existing.renterPhone || contact.renterPhone;
    existing.renterEmail = existing.renterEmail || contact.renterEmail;

    if (existing.sourceTypes.indexOf(contact.sourceType) === -1) existing.sourceTypes.push(contact.sourceType);
    if (existing.sourceFiles.indexOf(contact.sourceFileName) === -1) existing.sourceFiles.push(contact.sourceFileName);
    if (existing.sourceLocations.indexOf(contact.sourceSheetName) === -1) existing.sourceLocations.push(contact.sourceSheetName);
    if (contact.sourceRow !== "" && existing.sourceRows.indexOf(contact.sourceRow) === -1) existing.sourceRows.push(contact.sourceRow);
  });
}

function buildContactKey_(contact) {
  const email = normalizeEmail_(contact.renterEmail);
  if (email) return `email:${email}`;

  const phone = normalizePhone_(contact.renterPhone);
  if (phone) return `phone:${phone}`;

  const name = normalizeName_(contact.renterName);
  return name ? `name:${name}` : "";
}

function normalizeEmail_(value) {
  return String(value || "").trim().toLowerCase();
}

function normalizePhone_(value) {
  return String(value || "").replace(/\D/g, "");
}

function normalizeName_(value) {
  return String(value || "").trim().replace(/\s+/g, " ").toLowerCase();
}

function normalizeHeader_(value) {
  return String(value || "").toLowerCase().replace(/[^a-z0-9]/g, "");
}

function getContactsSpreadsheet_() {
  return SpreadsheetApp.openById(CONTACTS_DESTINATION_SPREADSHEET_ID);
}

function getContactsSheet_() {
  const spreadsheet = getContactsSpreadsheet_();
  const contactsSheet = spreadsheet.getSheetByName(CONTACTS_MASTER_SHEET_NAME);
  if (!contactsSheet) {
    throw new Error(`Sheet '${CONTACTS_MASTER_SHEET_NAME}' not found.`);
  }
  return contactsSheet;
}

function findExactCell_(sheet, text) {
  return sheet.createTextFinder(text).matchEntireCell(true).findNext();
}

function buildCheckboxRule_() {
  return SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
}

function getContactsSelectAllRange_() {
  const spreadsheet = getContactsSpreadsheet_();
  const selectAllRange = spreadsheet.getRangeByName(CONTACTS_SELECT_ALL_RANGE_NAME);
  if (!selectAllRange) {
    throw new Error(`Named range '${CONTACTS_SELECT_ALL_RANGE_NAME}' not found.`);
  }
  return selectAllRange;
}

function findHeaderColumnInRow_(headers, possibleHeaders) {
  const normalizedPossible = possibleHeaders.map(normalizeHeader_);

  for (let i = 0; i < headers.length; i++) {
    const normalizedHeader = normalizeHeader_(headers[i]);
    if (normalizedPossible.indexOf(normalizedHeader) !== -1) {
      return i + 1;
    }
  }

  return 0;
}

function writeContactsSheet_(contacts, statusLog) {
  const destination = SpreadsheetApp.openById(CONTACTS_DESTINATION_SPREADSHEET_ID);
  const tabName = `Contacts-${Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyyMMdd")}`;
  const existingSheet = destination.getSheetByName(tabName);

  if (existingSheet) {
    destination.deleteSheet(existingSheet);
    addGenerateContactsStatus_(statusLog, "Output sheet", true, `Replaced existing '${tabName}' tab.`);
  }

  const sheet = destination.insertSheet(tabName);
  const headers = [[
    "Renter Name",
    "Renter Phone",
    "Renter Email",
    "Source Types",
    "Source Files",
    "Source Locations",
    "Source Rows"
  ]];

  sheet.getRange(1, 1, 1, headers[0].length).setValues(headers);
  sheet.getRange(1, 1, 1, headers[0].length).setFontWeight("bold");

  if (contacts.length) {
    const rows = contacts.map(contact => [
      contact.renterName,
      contact.renterPhone,
      contact.renterEmail,
      contact.sourceTypes.join(", "),
      contact.sourceFiles.join(", "),
      contact.sourceLocations.join(", "),
      contact.sourceRows.join(", ")
    ]);

    sheet.getRange(2, 1, rows.length, rows[0].length).setValues(rows);
  }

  sheet.setFrozenRows(1);
  sheet.autoResizeColumns(1, headers[0].length);
  return tabName;
}

function findExistingContactsSheetRowByName_(sheet, headerRow, renterName) {
  const nextCell = findExactCell_(sheet, "{{next}}");
  if (!nextCell) return 0;

  const lastDataRow = nextCell.getRow() - 1;
  if (lastDataRow <= headerRow) return 0;

  const headers = sheet.getRange(headerRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];
  const nameCol = findHeaderColumnInRow_(headers, ["Renter Name"]);
  if (!nameCol) return 0;

  const values = sheet.getRange(headerRow + 1, 1, lastDataRow - headerRow, sheet.getLastColumn()).getDisplayValues();
  const normalizedTargetName = normalizeName_(renterName);

  for (let i = 0; i < values.length; i++) {
    const rowName = normalizeName_(values[i][nameCol - 1]);
    if (normalizedTargetName && rowName === normalizedTargetName) {
      return headerRow + 1 + i;
    }
  }

  return 0;
}

function insertContactsSheetRow_(sheet, headers, renterName, renterPhone, renterEmail, notes) {
  const nextCell = findExactCell_(sheet, "{{next}}");
  if (!nextCell) {
    throw new Error(`Cannot find {{next}} placeholder in '${sheet.getName()}'.`);
  }

  const insertRow = nextCell.getRow();
  sheet.insertRowBefore(insertRow);

  const rowValues = headers.map(header => {
    const cleanHeader = String(header || "").trim();
    if (cleanHeader === "Renter Name") return renterName || "";
    if (cleanHeader === "Renter Phone") return renterPhone || "";
    if (cleanHeader === "Renter Email") return renterEmail || "";
    if (cleanHeader === "Notes") return notes || "";
    return "";
  });

  sheet.getRange(insertRow, 1, 1, rowValues.length).setValues([rowValues]);
  sheet.getRange(insertRow, CONTACTS_SELECT_COLUMN).setDataValidation(buildCheckboxRule_()).setValue(false);
  return insertRow;
}

function setupContactsSelection() {
  const contactsSheet = getContactsSheet_();
  const statusLog = [];
  const nextCell = findExactCell_(contactsSheet, "{{next}}");

  if (!nextCell) {
    addGenerateContactsStatus_(statusLog, "Contacts selection", false, `Cannot find {{next}} placeholder in '${CONTACTS_MASTER_SHEET_NAME}'.`);
    showGenerateContactsStatus_("Contacts Selection Setup", statusLog);
    return;
  }

  const selectAllRange = getContactsSelectAllRange_();
  selectAllRange.setDataValidation(buildCheckboxRule_()).setValue(false);
  selectAllRange.offset(0, 1).setValue("Select All");

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount > 0) {
    const range = contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, CONTACTS_SELECT_COLUMN, dataRowCount, 1);
    const currentValues = range.getValues().map(row => [row[0] === true]);
    range.setDataValidation(buildCheckboxRule_());
    range.setValues(currentValues);
  }

  addGenerateContactsStatus_(statusLog, "Contacts selection", true, `Checkboxes are ready in ${selectAllRange.getA1Notation()} and A${CONTACTS_FIRST_DATA_ROW}:A.`);
  showGenerateContactsStatus_("Contacts Selection Setup", statusLog);
}

function toggleAllContactSelections_(contactsSheet, shouldSelect) {
  const nextCell = findExactCell_(contactsSheet, "{{next}}");
  if (!nextCell) {
    throw new Error(`Cannot find {{next}} placeholder in '${CONTACTS_MASTER_SHEET_NAME}'.`);
  }

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount <= 0) return 0;

  const values = Array.from({ length: dataRowCount }, () => [shouldSelect]);
  contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, CONTACTS_SELECT_COLUMN, dataRowCount, 1).setValues(values);
  return dataRowCount;
}

function clearAllContactSelections_(contactsSheet) {
  const nextCell = findExactCell_(contactsSheet, "{{next}}");
  if (!nextCell) {
    throw new Error(`Cannot find {{next}} placeholder in '${CONTACTS_MASTER_SHEET_NAME}'.`);
  }

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount > 0) {
    contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, CONTACTS_SELECT_COLUMN, dataRowCount, 1)
      .setValues(Array.from({ length: dataRowCount }, () => [false]));
  }

  getContactsSelectAllRange_().setValue(false);
}

function getPreferredDraftFromAddress_() {
  const activeEmail = Session.getActiveUser().getEmail();
  if (String(activeEmail || "").toLowerCase() === HHR_EMAIL_ADDRESS.toLowerCase()) {
    return HHR_EMAIL_ADDRESS;
  }

  const aliases = GmailApp.getAliases().map(alias => String(alias || "").toLowerCase());
  if (aliases.includes(HHR_EMAIL_ADDRESS.toLowerCase())) {
    return HHR_EMAIL_ADDRESS;
  }

  return "";
}

function isUsableRecipientEmail_(value) {
  const normalizedEmail = normalizeEmail_(value);
  if (!normalizedEmail) return false;
  if (normalizedEmail === "outdoorsy" || normalizedEmail === "n/a") return false;
  if (normalizedEmail === normalizeEmail_(HHR_EMAIL_ADDRESS)) return false;
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(normalizedEmail);
}

function createSelectedContactsEmail() {
  const spreadsheet = getContactsSpreadsheet_();
  const contactsSheet = getContactsSheet_();

  const nextCell = findExactCell_(contactsSheet, "{{next}}");
  if (!nextCell) {
    SpreadsheetApp.getUi().alert("Create Email", `Cannot find {{next}} placeholder in '${CONTACTS_MASTER_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const headers = contactsSheet.getRange(CONTACTS_HEADER_ROW, 1, 1, contactsSheet.getLastColumn()).getDisplayValues()[0];
  const emailCol = findHeaderColumnInRow_(headers, ["Renter Email"]);
  if (!emailCol) {
    SpreadsheetApp.getUi().alert("Create Email", `Column 'Renter Email' not found in '${CONTACTS_MASTER_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount <= 0) {
    SpreadsheetApp.getUi().alert("Create Email", `No renter rows found in '${CONTACTS_MASTER_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const values = contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, 1, dataRowCount, contactsSheet.getLastColumn()).getDisplayValues();
  const selectedEmails = [];
  const seenEmails = {};
  let selectedCount = 0;

  values.forEach(rowValues => {
    const isSelected = String(rowValues[CONTACTS_SELECT_COLUMN - 1] || "").toUpperCase() === "TRUE";
    if (!isSelected) return;

    selectedCount++;
    const renterEmail = String(rowValues[emailCol - 1] || "").trim();
    if (!isUsableRecipientEmail_(renterEmail)) return;

    const normalizedEmail = renterEmail.toLowerCase();
    if (seenEmails[normalizedEmail]) return;
    seenEmails[normalizedEmail] = true;
    selectedEmails.push(renterEmail);
  });

  if (!selectedCount) {
    SpreadsheetApp.getUi().alert("Create Email", "No renters are selected.", SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  if (!selectedEmails.length) {
    clearAllContactSelections_(contactsSheet);
    SpreadsheetApp.getUi().alert("Create Email", "Selected renters did not have any email addresses.", SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const draftFrom = getPreferredDraftFromAddress_();
  const draftTo = draftFrom || Session.getActiveUser().getEmail();
  const subjectRange = spreadsheet.getRangeByName(CONTACTS_EMAIL_SUBJECT_RANGE_NAME);
  const draftSubject = subjectRange
    ? String(subjectRange.getDisplayValue() || "").trim() || CONTACTS_EMAIL_DRAFT_SUBJECT
    : CONTACTS_EMAIL_DRAFT_SUBJECT;
  const options = {
    bcc: selectedEmails.join(","),
    name: "Happy Hooker Rentals",
    replyTo: HHR_EMAIL_ADDRESS
  };

  if (draftFrom) {
    options.from = draftFrom;
  }

  GmailApp.createDraft(
    draftTo,
    draftSubject,
    "",
    options
  );

  clearAllContactSelections_(contactsSheet);

  SpreadsheetApp.getUi().alert(
    "Create Email",
    `A draft email is created in ${draftTo} to ${selectedEmails.length} recipients that were selected.`,
    SpreadsheetApp.getUi().ButtonSet.OK
  );
}

function syncContactsToGoogleContacts_(contacts, statusLog) {
  if (typeof People === "undefined") {
    throw new Error("People API advanced service is not enabled. In Apps Script, enable Services > People API before running GenerateContacts again.");
  }

  const contactsIndex = getGoogleContactsIndex_();
  const group = getContactGroupByName_(CONTACTS_GROUP_NAME);
  const results = {
    created: 0,
    alreadyPresent: 0,
    grouped: 0,
    errors: 0
  };

  contacts.forEach(contactData => {
    try {
      let person = findIndexedGoogleContact_(contactsIndex, contactData);

      if (!person) {
        person = createGoogleContact_(contactData);
        results.created++;
      } else {
        results.alreadyPresent++;
      }

      if (group && person.resourceName && !isPersonInGroup_(person, group.resourceName)) {
        People.ContactGroups.Members.modify(
          { resourceNamesToAdd: [person.resourceName] },
          group.resourceName
        );
        results.grouped++;
      }

      addPersonToContactsIndex_(contactsIndex, person);
    } catch (e) {
      results.errors++;
      Logger.log(`GenerateContacts sync error for '${contactData.renterEmail}': ${e}`);
    }
  });

  addGenerateContactsStatus_(
    statusLog,
    "Google Contacts sync",
    results.errors === 0,
    `Created ${results.created}, already present ${results.alreadyPresent}, grouped ${results.grouped}, errors ${results.errors}.`
  );

  if (group) {
    addGenerateContactsStatus_(statusLog, "Google Contacts group", true, `Used contact group '${CONTACTS_GROUP_NAME}'.`);
  } else {
    addGenerateContactsStatus_(statusLog, "Google Contacts group", false, `Contact group '${CONTACTS_GROUP_NAME}' was not found.`);
  }
}

function getGoogleContactsIndex_() {
  const index = {
    byEmail: {},
    byPhone: {},
    byName: {}
  };
  let pageToken;

  do {
    const response = People.People.Connections.list("people/me", {
      personFields: "names,emailAddresses,phoneNumbers,memberships",
      pageSize: 1000,
      pageToken: pageToken
    });
    const connections = response.connections || [];
    connections.forEach(person => addPersonToContactsIndex_(index, person));
    pageToken = response.nextPageToken;
  } while (pageToken);

  return index;
}

function addPersonToContactsIndex_(index, person) {
  if (!person || !person.resourceName) return;

  getPersonEmailAddresses_(person).forEach(email => {
    const normalized = normalizeEmail_(email);
    if (normalized && !index.byEmail[normalized]) index.byEmail[normalized] = person;
  });

  getPersonPhoneNumbers_(person).forEach(phone => {
    const normalized = normalizePhone_(phone);
    if (normalized && !index.byPhone[normalized]) index.byPhone[normalized] = person;
  });

  getPersonDisplayNames_(person).forEach(name => {
    const normalized = normalizeName_(name);
    if (normalized && !index.byName[normalized]) index.byName[normalized] = person;
  });
}

function findIndexedGoogleContact_(index, contactData) {
  const email = normalizeEmail_(contactData.renterEmail);
  if (email && index.byEmail[email]) return index.byEmail[email];

  const phone = normalizePhone_(contactData.renterPhone);
  if (phone && index.byPhone[phone]) return index.byPhone[phone];

  const name = normalizeName_(contactData.renterName);
  if (name && index.byName[name]) return index.byName[name];

  return null;
}

function createGoogleContact_(contactData) {
  const nameParts = splitContactName_(contactData.renterName);
  const person = {
    names: [{
      givenName: nameParts.givenName,
      familyName: nameParts.familyName,
      displayName: contactData.renterName
    }]
  };

  if (contactData.renterEmail) {
    person.emailAddresses = [{ value: contactData.renterEmail }];
  }

  if (contactData.renterPhone) {
    person.phoneNumbers = [{ value: contactData.renterPhone }];
  }

  return People.People.createContact(person);
}

function getContactGroupByName_(name) {
  if (!name) return null;

  let pageToken;
  do {
    const response = People.ContactGroups.list({
      pageSize: 1000,
      pageToken: pageToken,
      groupFields: "name,memberCount,metadata"
    });
    const groups = response.contactGroups || [];
    const match = groups.find(group => String(group.name || "").trim().toLowerCase() === String(name).trim().toLowerCase());
    if (match) return match;
    pageToken = response.nextPageToken;
  } while (pageToken);

  return null;
}

function isPersonInGroup_(person, groupResourceName) {
  const memberships = person.memberships || [];
  return memberships.some(membership => {
    return membership.contactGroupMembership &&
      membership.contactGroupMembership.contactGroupResourceName === groupResourceName;
  });
}

function getPersonEmailAddresses_(person) {
  return (person.emailAddresses || []).map(email => String(email.value || "").trim()).filter(Boolean);
}

function getPersonPhoneNumbers_(person) {
  return (person.phoneNumbers || []).map(phone => String(phone.value || "").trim()).filter(Boolean);
}

function getPersonDisplayNames_(person) {
  return (person.names || [])
    .map(name => String(name.displayName || name.unstructuredName || "").trim())
    .filter(Boolean);
}

function splitContactName_(fullName) {
  const trimmed = String(fullName || "").trim();
  if (!trimmed) {
    return {
      givenName: "Unknown",
      familyName: "Customer"
    };
  }

  const parts = trimmed.split(/\s+/);
  return {
    givenName: parts.shift() || trimmed,
    familyName: parts.join(" ") || "."
  };
}

function addGenerateContactsStatus_(statusLog, step, success, detail) {
  const message = `${success ? "OK" : "WARN"} ${step}: ${detail}`;
  statusLog.push(message);
  Logger.log(`${success ? "SUCCESS" : "WARNING"} - ${step}: ${detail}`);
}

function showGenerateContactsStatus_(title, statusLog) {
  const message = statusLog && statusLog.length ? statusLog.join("\n") : "No status messages were recorded.";
  try {
    SpreadsheetApp.getUi().alert(title, message, SpreadsheetApp.getUi().ButtonSet.OK);
  } catch (e) {
    Logger.log(`${title}: ${message}`);
  }
}
