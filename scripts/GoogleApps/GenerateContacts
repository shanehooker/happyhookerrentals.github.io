function GenerateContacts() {
  const statusLog = [];

  try {
    const renters = {};

    const spreadsheetContacts = collectContactsFromBookingFolder_(statusLog);
    addContactsToMap_(renters, spreadsheetContacts);

    const agreementContacts = collectContactsFromAgreementFolders_(statusLog);
    addContactsToMap_(renters, agreementContacts);

    const contacts = Object.keys(renters)
      .map(key => renters[key])
      .sort((a, b) => {
        const nameCompare = String(a.renterName || "").localeCompare(String(b.renterName || ""));
        if (nameCompare !== 0) return nameCompare;
        return String(a.renterEmail || "").localeCompare(String(b.renterEmail || ""));
      });

    const tabName = writeContactsSheet_(contacts, statusLog);
    addGenerateContactsStatus_(statusLog, "Output sheet", true, `Created '${tabName}' with ${contacts.length} unique contact(s).`);
    syncContactsToGoogleContacts_(contacts, statusLog);
  } catch (e) {
    addGenerateContactsStatus_(statusLog, "GenerateContacts", false, e.toString());
  }

  showGenerateContactsStatus_("Generate Contacts Status", statusLog);
}

