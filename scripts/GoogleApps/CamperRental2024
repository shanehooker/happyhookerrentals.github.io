function updateQuoteTriggerStatusFromLog_(bookingId, statusLog, forceError) {
  const hasWarnings = statusLog.some(message => String(message || "").indexOf("⚠️") === 0);
  const isError = forceError === true;
  const color = isError ? "#f4cccc" : (hasWarnings ? "#fce5cd" : "#d9ead3");

  let message = bookingId
    ? `Quote ${bookingId} created successfully.`
    : "Quote completed successfully.";

  if (hasWarnings) {
    message = bookingId
      ? `Quote ${bookingId} completed with warnings.`
      : "Quote completed with warnings.";
  }

  if (isError) {
    const lastStatus = statusLog.length ? String(statusLog[statusLog.length - 1]) : "Quote failed.";
    message = lastStatus;
  }

  setQuoteTriggerStatus_(message, color);
}

function getCheckboxConfirmationKey_(sheet, row, col, actionName) {
  return [
    "checkboxConfirm",
    sheet.getParent().getId(),
    sheet.getSheetId(),
    row,
    col,
    actionName
  ].join(":");
}

function requireCheckboxConfirmation_(sheet, row, col, actionName, promptText) {
  const properties = PropertiesService.getDocumentProperties();
  const key = getCheckboxConfirmationKey_(sheet, row, col, actionName);
  const now = Date.now();
  const existingRaw = properties.getProperty(key);

  if (existingRaw) {
    try {
      const existing = JSON.parse(existingRaw);
      if (existing && now - Number(existing.timestamp || 0) <= CHECKBOX_CONFIRM_WINDOW_MS) {
        properties.deleteProperty(key);
        return true;
      }
    } catch (e) {
      Logger.log(`Could not parse checkbox confirmation state for ${key}: ${e}`);
    }
  }

  properties.setProperty(key, JSON.stringify({ timestamp: now }));
  sheet.getRange(row, col).setValue(false);
  showMessage_(
    `${actionName} Confirmation`,
    `${promptText} Check the box again within 30 seconds to confirm.`,
    { preferToastOnly: true, toastSeconds: 10 }
  );
  return false;
}

function clearCheckboxConfirmation_(sheet, row, col, actionName) {
  const properties = PropertiesService.getDocumentProperties();
  properties.deleteProperty(getCheckboxConfirmationKey_(sheet, row, col, actionName));
}

function getColumnByHeader_(sheet, headerRow, headerName) {
  const headers = sheet.getRange(headerRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

  for (let i = 0; i < headers.length; i++) {
    if (String(headers[i]).trim() === headerName) {
      return i + 1;
    }
  }

  return null;
}

function getRowDataByHeaders_(sheet, headerRow, dataRow) {
  const headers = sheet.getRange(headerRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];
  const values = sheet.getRange(dataRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

  const data = {};

  headers.forEach((header, i) => {
    if (header) data[String(header).trim()] = values[i];
  });

  return data;
}

function ensureCheckboxColumn_(sheet, headerRow, headerName) {
  let col = getColumnByHeader_(sheet, headerRow, headerName);
  if (!col) {
    col = sheet.getLastColumn() + 1;
    sheet.getRange(headerRow, col).setValue(headerName);
  }

  const lastRow = sheet.getLastRow();
  if (lastRow <= headerRow) return col;

  const range = sheet.getRange(headerRow + 1, col, lastRow - headerRow, 1);
  const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
  const normalizedValues = range.getValues().map(row => [row[0] === true]);

  range.setDataValidation(rule);
  range.setValues(normalizedValues);

  return col;
}

