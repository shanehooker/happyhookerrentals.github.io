function createInvoiceFromTemplate_(bookingId, renterName) {
  const templateFile = getDriveFileByIdOrName_(INVOICE_TEMPLATE_ID, INVOICE_TEMPLATE_NAME);
  if (!templateFile) {
    throw new Error(`Invoice template '${INVOICE_TEMPLATE_NAME}' not found.`);
  }

  const folder = DriveApp.getFolderById(QUOTE_FOLDER_ID);

  const safeBooking = safeNoSpaces_(bookingId);
  const safeName = safeNoSpaces_(renterName);
  const invoiceName = `${safeBooking}-${safeName}-Invoice`;

  const newFile = templateFile.makeCopy(invoiceName, folder);
  const newFileId = newFile.getId();

  // Replace existing invoices only after the new copy has been created successfully.
  const existingFiles = folder.getFilesByName(invoiceName);
  let replacedCount = 0;
  while (existingFiles.hasNext()) {
    const existingFile = existingFiles.next();
    if (existingFile.getId() === newFileId) continue;
    existingFile.setTrashed(true);
    replacedCount++;
  }

  return {
    file: newFile,
    name: invoiceName,
    replacedCount: replacedCount
  };
}

function normalizeAgreementKey_(key) {
  return String(key || "")
    .replace(/[:]/g, "")
    .replace(/\s+/g, "")
    .toLowerCase()
    .trim();
}

function extractFieldsFromAgreementDoc_(docFile) {
  const doc = DocumentApp.openById(docFile.getId());
  const body = doc.getBody();
  const fields = {};

  function saveField(label, value) {
    label = String(label || "").trim();
    value = String(value || "").trim();

    if (!label || !value) return;

    // Remove leftover placeholder wrappers if a template label was written as <<paymentTerms>>.
    label = label.replace(/^<<\s*/, "").replace(/\s*>>$/, "");

    fields[normalizeAgreementKey_(label)] = value;
  }

  const tables = body.getTables();

  tables.forEach(table => {
    for (let r = 0; r < table.getNumRows(); r++) {
      const row = table.getRow(r);
      const cellTexts = [];

      for (let c = 0; c < row.getNumCells(); c++) {
        cellTexts.push(row.getCell(c).getText().trim());
      }

      // Common case: label in first cell, value in the next non-empty cell to the right.
      if (cellTexts.length >= 2 && cellTexts[0]) {
        const firstValueToRight = cellTexts.slice(1).find(text => text !== "");
        if (firstValueToRight) saveField(cellTexts[0], firstValueToRight);
      }

      // More flexible case: any cell can be a label, and the next non-empty cell is the value.
      for (let c = 0; c < cellTexts.length - 1; c++) {
        const label = cellTexts[c];
        if (!label) continue;

        const value = cellTexts.slice(c + 1).find(text => text !== "");
        if (value) saveField(label, value);
      }
    }
  });

  const text = body.getText();
  const lines = text.split(/\r?\n/).map(line => line.trim()).filter(line => line !== "");

  lines.forEach((line, index) => {
    // Supports "Payment Terms: Due before delivery"
    const inlineMatch = line.match(/^(.+?)\s*:\s*(.+)$/);

    if (inlineMatch) {
      saveField(inlineMatch[1], inlineMatch[2]);
      return;
    }

    // Supports two-line patterns:
    // Payment Terms:
    // Due before delivery
    const labelOnlyMatch = line.match(/^(.+?)\s*:\s*$/);
    if (labelOnlyMatch && lines[index + 1]) {
      saveField(labelOnlyMatch[1], lines[index + 1]);
    }
  });

  return fields;
}

function getAgreementValue_(agreementFields, possibleNames) {
  for (const name of possibleNames) {
    const key = normalizeAgreementKey_(name);
    if (agreementFields[key] !== undefined && String(agreementFields[key]).trim() !== "") {
      return agreementFields[key];
    }
  }

  return "";
}


function getAgreementPlainText_(docFile) {
  const doc = DocumentApp.openById(docFile.getId());
  return doc.getBody().getText();
}

function getNonEmptyAgreementLines_(agreementText) {
  return String(agreementText || "")
    .split(/\r?\n/)
    .map(line => String(line || "").trim())
    .filter(line => line !== "");
}

function findLineIndexContaining_(lines, possibleLabels) {
  const normalizedLabels = possibleLabels.map(label => String(label || "").toLowerCase());

  for (let i = 0; i < lines.length; i++) {
    const line = String(lines[i] || "").toLowerCase();
    if (normalizedLabels.some(label => line.indexOf(label) !== -1)) {
      return i;
    }
  }

  return -1;
}

function findFirstMoneyInLines_(lines, startIndex, maxLines) {
  const endIndex = Math.min(lines.length, startIndex + maxLines);
  const moneyRegex = /\$\s*\d[\d,]*(?:\.\d{2})?|\b\d[\d,]*\.\d{2}\b/g;

  for (let i = startIndex; i < endIndex; i++) {
    const matches = String(lines[i] || "").match(moneyRegex);
    if (matches && matches.length) {
      let value = matches[0].replace(/\s+/g, "");
      if (!value.startsWith("$")) value = "$" + value;
      return value;
    }
  }

  return "";
}

function extractCostDiscountFields_(agreementText) {
  const lines = getNonEmptyAgreementLines_(agreementText);
  const result = {
    rentalCostNightly: "",
    rentalCost: ""
  };

  const startIndex = findLineIndexContaining_(lines, ["costs/discounts", "costs / discounts"]);
  if (startIndex === -1) return result;

  const endIndex = Math.min(lines.length, startIndex + 20);
  const nightlyRegex = /(\d+)\s*nights?\s*@\s*\$?\s*([\d,]+(?:\.\d{2})?)\s*\/\s*night/i;

  for (let i = startIndex; i < endIndex; i++) {
    const line = String(lines[i] || "");
    const match = line.match(nightlyRegex);

    if (match) {
      result.rentalCostNightly = `${match[1]} nights @$${match[2].replace(/,/g, "")}/night`;

      // Prefer a dollar amount after the nightly pattern on the same line; otherwise scan the next few fields/lines.
      const afterNightlyText = line.slice(match.index + match[0].length);
      let sameLineMoney = findFirstMoneyInLines_([afterNightlyText], 0, 1);
      result.rentalCost = sameLineMoney || findFirstMoneyInLines_(lines, i + 1, 6);
      return result;
    }
  }

  return result;
}

function extractMoneyAfterLabel_(agreementText, possibleLabels, maxLines) {
  const lines = getNonEmptyAgreementLines_(agreementText);
  const startIndex = findLineIndexContaining_(lines, possibleLabels);
  if (startIndex === -1) return "";
  return findFirstMoneyInLines_(lines, startIndex, maxLines || 8);
}

function extractSectionBetweenLabels_(agreementText, startLabels, endLabels) {
  const lines = getNonEmptyAgreementLines_(agreementText);
  const startIndex = findLineIndexContaining_(lines, startLabels);
  if (startIndex === -1) return "";

  let endIndex = lines.length;
  const normalizedEndLabels = endLabels.map(label => String(label || "").toLowerCase());

  for (let i = startIndex + 1; i < lines.length; i++) {
    const line = String(lines[i] || "").toLowerCase();
    if (normalizedEndLabels.some(label => line.indexOf(label) !== -1)) {
      endIndex = i;
      break;
    }
  }

  return lines.slice(startIndex + 1, endIndex).join("\n").trim();
}

function extractInvoiceFieldsFromAgreementText_(docFile) {
  const agreementText = getAgreementPlainText_(docFile);
  const costFields = extractCostDiscountFields_(agreementText);

  return {
    rentalCostNightly: costFields.rentalCostNightly,
    rentalCost: costFields.rentalCost,
    NHMRTax: extractMoneyAfterLabel_(agreementText, [
      "nh meals/room tax",
      "nh meals / room tax",
      "nh meals and rooms tax",
      "nh meals & rooms tax"
    ], 8),
    deliveryCost: extractMoneyAfterLabel_(agreementText, [
      "delivery/setup charge",
      "delivery / setup charge",
      "delivery setup charge",
      "delivery charge",
      "setup charge"
    ], 8),
    paymentTerms: extractSectionBetweenLabels_(agreementText, [
      "payment terms"
    ], [
      "cancellation terms"
    ])
  };
}

function getPaymentsForBooking_(ss, bookingId) {
  const incomeSheet = ss.getSheetByName(INCOME_SHEET_NAME);

  if (!incomeSheet) {
    throw new Error(`Income sheet '${INCOME_SHEET_NAME}' not found.`);
  }

  const lastRow = incomeSheet.getLastRow();
  const lastCol = incomeSheet.getLastColumn();

  if (lastRow < 1 || lastCol < 1) {
    return {
      descriptions: "",
      dates: "",
      amounts: "",
      totalPaid: 0,
      count: 0
    };
  }

  function normalizeHeader_(value) {
    return String(value || "").toLowerCase().replace(/[^a-z0-9]/g, "");
  }

  function findHeaderColInRow_(headers, possibleHeaders) {
    const normalizedPossible = possibleHeaders.map(normalizeHeader_);

    for (let i = 0; i < headers.length; i++) {
      const normalizedHeader = normalizeHeader_(headers[i]);
      if (normalizedPossible.includes(normalizedHeader)) {
        return i + 1;
      }
    }

    return 0;
  }

  // The Income sheet may have summary/totals rows above the actual transaction table.
  // Scan the first 30 rows and find the row that contains all required headers.
  const scanRows = Math.min(lastRow, 30);
  const scannedValues = incomeSheet.getRange(1, 1, scanRows, lastCol).getDisplayValues();

  let headerRow = 0;
  let bookingIdCol = 0;
  let descriptionCol = 0;
  let dateCol = 0;
  let amountCol = 0;

  for (let r = 0; r < scannedValues.length; r++) {
    const rowHeaders = scannedValues[r];

    const testBookingIdCol = findHeaderColInRow_(rowHeaders, ["Booking ID", "Booking Id", "BookingId", "bookingId"]);
    const testDescriptionCol = findHeaderColInRow_(rowHeaders, ["Description", "Payment Description", "PaymentDescription"]);
    const testDateCol = findHeaderColInRow_(rowHeaders, ["Date", "Payment Date", "PaymentDate"]);
    const testAmountCol = findHeaderColInRow_(rowHeaders, ["Amount", "Payment", "Payment Amount", "PaymentAmount"]);

    if (testBookingIdCol && testDescriptionCol && testDateCol && testAmountCol) {
      headerRow = r + 1;
      bookingIdCol = testBookingIdCol;
      descriptionCol = testDescriptionCol;
      dateCol = testDateCol;
      amountCol = testAmountCol;
      break;
    }
  }

  if (!headerRow) {
    const scannedPreview = scannedValues
      .map((row, index) => `Row ${index + 1}: ${row.join(", ")}`)
      .join(" | ");

    throw new Error(
      "Income sheet must have one row containing headers for Booking Id, Description, Date, and Amount. " +
      "The script scanned the first 30 rows but did not find them together. Scanned rows: " + scannedPreview
    );
  }

  if (lastRow <= headerRow) {
    return {
      descriptions: "",
      dates: "",
      amounts: "",
      totalPaid: 0,
      count: 0,
      headerRow
    };
  }

  const rows = incomeSheet.getRange(headerRow + 1, 1, lastRow - headerRow, lastCol).getDisplayValues();

  const matched = [];
  let totalPaid = 0;

  rows.forEach(row => {
    const rowBookingId = String(row[bookingIdCol - 1]).trim();

    if (rowBookingId === String(bookingId).trim()) {
      const description = row[descriptionCol - 1];
      const date = row[dateCol - 1];
      const amountRaw = row[amountCol - 1];
      const amount = parseMoney_(amountRaw);

      totalPaid += amount;

      matched.push({
        description,
        date,
        amountDisplay: formatMoney_(amount),
        amount
      });
    }
  });

  return {
    descriptions: matched.map(p => p.description).join("\n"),
    dates: matched.map(p => p.date).join("\n"),
    amounts: matched.map(p => p.amountDisplay).join("\n"),
    totalPaid,
    count: matched.length,
    headerRow
  };
}

function replaceInvoicePlaceholders_(spreadsheetFile, mergeValues) {
  const invoiceSs = SpreadsheetApp.openById(spreadsheetFile.getId());

  // TemplateInvoice-2026 now contains a single sheet named "Invoice".
  // Use that sheet directly so old/deleted template sheets can never affect the merge.
  const invoiceSheet = invoiceSs.getSheetByName("Invoice");

  if (!invoiceSheet) {
    throw new Error("Invoice template must contain a sheet named 'Invoice'.");
  }

  Object.keys(mergeValues).forEach(key => {
    const placeholder = `<<${key}>>`;
    const value = String(mergeValues[key] ?? "");
    invoiceSheet.createTextFinder(placeholder).replaceAllWith(value);
  });

  SpreadsheetApp.flush();
}

/**
 * Run manually once after adding the Invoice column, or whenever you need to restore invoice checkboxes.
 */
function setupInvoiceColumn() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const bookingsSheet = ss.getSheetByName(BOOKINGS_SHEET_NAME);
  const headerRow = 3;

  if (!bookingsSheet) {
    SpreadsheetApp.getUi().alert(`Sheet '${BOOKINGS_SHEET_NAME}' not found.`);
    return;
  }

  let invoiceCol = getColumnByHeader_(bookingsSheet, headerRow, INVOICE_COLUMN_HEADER);

  if (!invoiceCol) {
    invoiceCol = bookingsSheet.getLastColumn() + 1;
    bookingsSheet.getRange(headerRow, invoiceCol).setValue(INVOICE_COLUMN_HEADER);
  }

  const lastRow = bookingsSheet.getLastRow();

  if (lastRow <= headerRow) {
    SpreadsheetApp.getUi().alert("Invoice column created. No booking rows found yet.");
    return;
  }

  const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
  const checkboxRange = bookingsSheet.getRange(headerRow + 1, invoiceCol, lastRow - headerRow, 1);

  checkboxRange.setDataValidation(rule);

  SpreadsheetApp.getUi().alert(`Invoice column is ready in column ${invoiceCol}.`);
}

function generateInvoice(row) {
  const statusLog = [];
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const bookingsSheet = ss.getSheetByName(BOOKINGS_SHEET_NAME);
  const headerRow = 3;

  try {
    if (!bookingsSheet) {
      throw new Error(`Sheet '${BOOKINGS_SHEET_NAME}' not found.`);
    }

    const bookingData = getRowDataByHeaders_(bookingsSheet, headerRow, row);

    const bookingId = bookingData["Booking ID"];
    const renterName = bookingData["Renter Name"];

    if (!bookingId || !renterName) {
      throw new Error("Booking ID or Renter Name missing from selected Bookings row.");
    }

    addStatus_(statusLog, "Invoice setup", true, `Booking ${bookingId} for ${renterName}.`);

    const agreementFile = findRentalAgreementFile_(bookingId, renterName);
    addStatus_(statusLog, "Rental agreement", true, `Found ${agreementFile.getName()}.`);

    const agreementFields = extractFieldsFromAgreementDoc_(agreementFile);
    addStatus_(statusLog, "Agreement data", true, "Extracted label/value fields from rental agreement.");

    const paymentData = getPaymentsForBooking_(ss, bookingId);
    addStatus_(statusLog, "Payments", true, `Found ${paymentData.count} payment row(s). Total paid: ${formatMoney_(paymentData.totalPaid)}.`);

    const invoice = createInvoiceFromTemplate_(bookingId, renterName);
    addStatus_(statusLog, "Invoice file", true, `Created ${invoice.name}${invoice.replacedCount ? ` after replacing ${invoice.replacedCount} existing invoice file(s)` : ""}.`);

    const textExtractedInvoiceFields = extractInvoiceFieldsFromAgreementText_(agreementFile);

    const rentalCostNightlyRaw =
      textExtractedInvoiceFields.rentalCostNightly ||
      getAgreementValue_(agreementFields, [
        "rentalCostNightly",
        "Rental Cost Nightly",
        "Rental Cost/Nightly",
        "Nightly Rental Cost",
        "Rental Rate",
        "Rate"
      ]);

    const rentalCostRaw =
      textExtractedInvoiceFields.rentalCost ||
      getAgreementValue_(agreementFields, [
        "rentalCost",
        "Rental Cost",
        "Rental Amount",
        "Base Rental Cost"
      ]);

    const totalCostRaw =
      getAgreementValue_(agreementFields, [
        "totalRentalCost",
        "Total Rental Cost",
        "totalCost",
        "Total Cost",
        "Expected Income"
      ]) ||
      bookingData["Expected Income"] ||
      bookingData["Total Cost"] ||
      "0";

    const totalCost = parseMoney_(totalCostRaw);
    const balance = totalCost - paymentData.totalPaid;

    const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");

    const mergeValues = {
      bookingId: bookingId,
      renterName: renterName,
      renterNameNoSpaces: safeNoSpaces_(renterName),

      paymentDescriptions: paymentData.descriptions,
      paymentDates: paymentData.dates,
      payments: paymentData.amounts,

      totalPaid: formatMoney_(paymentData.totalPaid),
      totalCost: formatMoney_(totalCost),       // backwards-compatible old placeholder
      totalRentalCost: formatMoney_(totalCost), // preferred invoice placeholder
      balance: formatMoney_(balance),

      rentalRate: rentalCostNightlyRaw,         // backwards-compatible old placeholder
      rentalCost: rentalCostRaw,                // dollar value, e.g. $304.00
      rentalCostNightly: rentalCostNightlyRaw,  // nightly description, e.g. 4 nights @$76/night

      NHMRTax: textExtractedInvoiceFields.NHMRTax || getAgreementValue_(agreementFields, [
        "NHMRTax",
        "NH MR Tax",
        "NH Meals/Room Tax",
        "NH Meals and Rooms Tax",
        "Meals and Rooms Tax",
        "M&R Tax",
        "Tax"
      ]),

      deliveryCost: textExtractedInvoiceFields.deliveryCost || getAgreementValue_(agreementFields, [
        "deliveryCost",
        "Delivery Cost",
        "Delivery/Setup Charge",
        "Delivery Setup Charge",
        "Delivery Fee",
        "Delivery"
      ]),

      addOnCost: getAgreementValue_(agreementFields, [
        "addOnCost",
        "Add On Cost",
        "Add-On Cost",
        "Add Ons",
        "Add-Ons",
        "Add On",
        "Add-On",
        "Addons"
      ]),

      paymentTerms: textExtractedInvoiceFields.paymentTerms || getAgreementValue_(agreementFields, [
        "paymentTerms",
        "Payment Terms",
        "Payment Term",
        "Terms",
        "Payment Schedule",
        "Payment Due",
        "Due Date",
        "Balance Due"
      ]),

      invoiceDate: today,
      today: today
    };

    Object.keys(bookingData).forEach(key => {
      const cleanKey = key.replace(/\s+/g, "");
      if (!mergeValues[cleanKey]) mergeValues[cleanKey] = bookingData[key];
    });

    Object.keys(agreementFields).forEach(key => {
      if (!mergeValues[key]) mergeValues[key] = agreementFields[key];
    });

    addStatus_(
      statusLog,
      "Invoice fields",
      true,
      `Mapped rentalCost='${mergeValues.rentalCost}', rentalCostNightly='${mergeValues.rentalCostNightly}', totalRentalCost='${mergeValues.totalRentalCost}', NHMRTax='${mergeValues.NHMRTax}', deliveryCost='${mergeValues.deliveryCost}', addOnCost='${mergeValues.addOnCost}', paymentTerms='${mergeValues.paymentTerms}'.`
    );

    replaceInvoicePlaceholders_(invoice.file, mergeValues);
    addStatus_(statusLog, "Invoice merge", true, "Replaced invoice placeholders.");

    const invoiceUrl = invoice.file.getUrl();

    showStatusLog_("Invoice Status", statusLog);

    const html = HtmlService.createHtmlOutput(`<script>
      window.open('${invoiceUrl}', '_blank');
      google.script.host.close();
    </script>`).setWidth(100).setHeight(50);

    SpreadsheetApp.getUi().showModalDialog(html, `Opening invoice ${invoice.name}...`);
  } catch (e) {
    addStatus_(statusLog, "Invoice error", false, e.toString());
    showStatusLog_("Invoice Status", statusLog);
    Logger.log("generateInvoice error: " + e);
  }
}

/**
 * Installable onEdit trigger to handle:
 * 1. Book checkbox clicks on Waiting to Book
 * 2. Cancel checkbox clicks on Waiting to Book
 * 3. Invoice checkbox clicks on Bookings
 * 4. Cancel checkbox clicks on Bookings
 */
function onEditHandler(e) {
  try {
    const range = e.range;
    const sheet = range.getSheet();

    if (!sheet) return;

    const sheetName = sheet.getName();
    const editedRow = range.getRow();
    const editedCol = range.getColumn();

    if (e.value !== "TRUE") return;

    const ui = SpreadsheetApp.getUi();

    // Existing Book workflow
    if (sheetName === WAITING_SHEET_NAME) {
      const cancelCol = getColumnByHeader_(sheet, WAITING_HEADER_ROW, CANCEL_COLUMN_HEADER);

      if (cancelCol && editedCol === cancelCol) {
        if (editedRow <= WAITING_HEADER_ROW) return;

        const rowData = getRowDataByHeaders_(sheet, WAITING_HEADER_ROW, editedRow);
        const bookingId = String(rowData["Booking ID"] || "").trim();
        const renterName = String(rowData["Renter Name"] || "").trim();
        const response = ui.alert(
          "Confirm Cancellation",
          `Cancel booking in row ${editedRow} for ${bookingId} ${renterName}?`,
          ui.ButtonSet.YES_NO
        );

        if (response !== ui.Button.YES) {
          sheet.getRange(editedRow, editedCol).setValue(false);
          return;
        }

        cancelReservation(sheet, editedRow, WAITING_HEADER_ROW);
        return;
      }

      if (editedCol !== 1) return;

      const response = ui.alert("Confirm Booking", `Move booking in row ${editedRow} to Bookings?`, ui.ButtonSet.YES_NO);

      if (response !== ui.Button.YES) {
        sheet.getRange(editedRow, 1).setValue(false);
        return;
      }

      bookReservation(editedRow);
      return;
    }

    // New Invoice workflow
    if (sheetName === BOOKINGS_SHEET_NAME) {
      const cancelCol = getColumnByHeader_(sheet, BOOKINGS_HEADER_ROW, CANCEL_COLUMN_HEADER);
      if (cancelCol && editedCol === cancelCol) {
        if (editedRow <= BOOKINGS_HEADER_ROW) return;

        const rowData = getRowDataByHeaders_(sheet, BOOKINGS_HEADER_ROW, editedRow);
        const bookingId = String(rowData["Booking ID"] || "").trim();
        const renterName = String(rowData["Renter Name"] || "").trim();
        const response = ui.alert(
          "Confirm Cancellation",
          `Cancel booking in row ${editedRow} for ${bookingId} ${renterName}?`,
          ui.ButtonSet.YES_NO
        );

        if (response !== ui.Button.YES) {
          sheet.getRange(editedRow, editedCol).setValue(false);
          return;
        }

        cancelReservation(sheet, editedRow, BOOKINGS_HEADER_ROW);
        return;
      }

      const invoiceCol = getColumnByHeader_(sheet, BOOKINGS_HEADER_ROW, INVOICE_COLUMN_HEADER);

      if (!invoiceCol || editedCol !== invoiceCol) return;
      if (editedRow <= BOOKINGS_HEADER_ROW) return;

      const response = ui.alert("Confirm Invoice", `Create invoice for booking row ${editedRow}?`, ui.ButtonSet.YES_NO);

      if (response !== ui.Button.YES) {
        sheet.getRange(editedRow, editedCol).setValue(false);
        return;
      }

      generateInvoice(editedRow);
      return;
    }
  } catch(err) {
    Logger.log("onEditHandler error: " + err);
    try {
      SpreadsheetApp.getUi().alert("onEditHandler error", String(err), SpreadsheetApp.getUi().ButtonSet.OK);
    } catch (uiErr) {
      Logger.log("Could not display onEditHandler error UI: " + uiErr);
    }
  }
}

/**
 * One-time setup to create installable onEdit trigger
 */
function setupOnEditTrigger() {
  const ss = SpreadsheetApp.getActive();
  const triggers = ScriptApp.getProjectTriggers();
  for (const t of triggers) {
    if (t.getHandlerFunction() === "onEditHandler") return;
  }
  ScriptApp.newTrigger("onEditHandler").forSpreadsheet(ss).onEdit().create();
}
