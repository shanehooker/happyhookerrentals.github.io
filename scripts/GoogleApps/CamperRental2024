function getDriveFileByIdOrName_(fileId, fileName) {
  if (fileId && String(fileId).trim() !== "") {
    return DriveApp.getFileById(String(fileId).trim());
  }

  const files = DriveApp.getFilesByName(fileName);
  if (!files.hasNext()) return null;

  const file = files.next();
  if (files.hasNext()) {
    Logger.log(`WARNING - Multiple Drive files found named '${fileName}'. Using the first match.`);
  }

  return file;
}

function findExactCell_(sheet, text) {
  return sheet.createTextFinder(text).matchEntireCell(true).findNext();
}

/**
 * Named range / document template merge helpers for TemplateRentalAgreement-2026.
 */
function getNamedRangeMergeValues_(ss) {
  const values = {};

  ss.getNamedRanges().forEach(namedRange => {
    const name = namedRange.getName();
    const range = namedRange.getRange();
    values[name] = range.getDisplayValue();
  });

  return values;
}

function escapeForReplaceText_(text) {
  return String(text).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function replaceNamedRangePlaceholders_(doc, mergeValues) {
  const body = doc.getBody();
  const header = doc.getHeader();
  const footer = doc.getFooter();

  Object.keys(mergeValues).forEach(name => {
    const placeholder = `<<${name}>>`;
    const escapedPlaceholder = escapeForReplaceText_(placeholder);
    const value = String(mergeValues[name] || "");

    body.replaceText(escapedPlaceholder, value);
    if (header) header.replaceText(escapedPlaceholder, value);
    if (footer) footer.replaceText(escapedPlaceholder, value);
  });
}

function getMergeValue_(mergeValues, possibleNames) {
  for (const name of possibleNames) {
    if (mergeValues[name] !== undefined && String(mergeValues[name]).trim() !== "") {
      return String(mergeValues[name]).trim();
    }
  }
  return "";
}

function parseSheetDate_(value) {
  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value)) {
    return value;
  }

  const parsed = new Date(value);
  return isNaN(parsed.getTime()) ? null : parsed;
}

