function clearAllContactSelections_(contactsSheet) {
  const nextCell = findExactCell_(contactsSheet, "{{next}}");
  if (!nextCell) {
    throw new Error(`Cannot find {{next}} placeholder in '${CONTACTS_SHEET_NAME}'.`);
  }

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount > 0) {
    contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, CONTACTS_SELECT_COLUMN, dataRowCount, 1)
      .setValues(Array.from({ length: dataRowCount }, () => [false]));
  }

