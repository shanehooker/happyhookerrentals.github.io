/**
 * Helper functions for distance and duration calculations
 */
const HOME_ADDRESS = "36 Juniper Dr, Amherst, NH";
const ROUTE_CACHE_TTL_SECONDS = 21600;

function MilesFromHome(address) {
  const routeSummary = getRouteSummaryFromHome_(address);
  return routeSummary.miles;
}

function HoursFromHome(address) {
  const routeSummary = getRouteSummaryFromHome_(address);
  return routeSummary.hours;
}

function metersToMiles(meters) {
  if (typeof meters !== 'number') return null;
  return meters / 1000 * 0.621371;
}

function getRouteSummaryFromHome_(address) {
  const destination = String(address || "").trim();
  if (!destination) return { miles: "unknown", hours: "unknown" };

  const cache = CacheService.getScriptCache();
  const cacheKey = getRouteCacheKey_(destination);
  const cachedSummary = cache.get(cacheKey);
  if (cachedSummary) {
    try {
      return JSON.parse(cachedSummary);
    } catch (e) {
      Logger.log(`Could not parse cached route summary for '${destination}': ${e}`);
    }
  }

  const directions = Maps.newDirectionFinder()
    .setOrigin(HOME_ADDRESS)
    .setDestination(destination)
    .setMode(Maps.DirectionFinder.Mode.DRIVING)
    .getDirections();

  if (directions && directions.error_message) throw new Error(directions.error_message);
  if (directions && directions.status && directions.status !== "OK") {
    throw new Error(`Directions lookup failed for '${destination}' with status '${directions.status}'.`);
  }

  const leg = directions &&
    directions.routes &&
    directions.routes[0] &&
    directions.routes[0].legs &&
    directions.routes[0].legs[0];

  if (!leg) {
    return { miles: "unknown", hours: "unknown" };
  }

  const routeSummary = {
    miles: leg.distance && typeof leg.distance.value === "number"
      ? metersToMiles(leg.distance.value)
      : "unknown",
    hours: leg.duration && leg.duration.text
      ? leg.duration.text
      : "unknown"
  };

  try {
    cache.put(cacheKey, JSON.stringify(routeSummary), ROUTE_CACHE_TTL_SECONDS);
  } catch (e) {
    Logger.log(`Could not cache route summary for '${destination}': ${e}`);
  }

  return routeSummary;
}

function getRouteCacheKey_(destination) {
  return `route:${String(destination || "").trim().toLowerCase()}`;
}


/**
 * Status log helpers used by quote, booking, and invoice workflows.
 */
function addStatus_(statusLog, step, success, detail) {
  const message = `${success ? "✅" : "⚠️"} ${step}: ${detail}`;
  statusLog.push(message);
  Logger.log(`${success ? "SUCCESS" : "WARNING"} - ${step}: ${detail}`);
}

function showStatusLog_(title, statusLog) {
  const message = statusLog && statusLog.length ? statusLog.join("\n") : "No status messages were recorded.";
  try {
    SpreadsheetApp.getUi().alert(title, message, SpreadsheetApp.getUi().ButtonSet.OK);
  } catch (e) {
    try {
      SpreadsheetApp.getActiveSpreadsheet().toast(message, title, 10);
    } catch (toastErr) {
      Logger.log(`Could not display toast for ${title}: ${toastErr}`);
    }
    Logger.log(`${title}: ${message}`);
  }
}

function showMessage_(title, message, options) {
  const settings = options || {};
  const preferToastOnly = settings.preferToastOnly === true;
  const toastSeconds = settings.toastSeconds || 8;

  if (!preferToastOnly) {
    try {
      SpreadsheetApp.getUi().alert(title, message, SpreadsheetApp.getUi().ButtonSet.OK);
      return;
    } catch (e) {
      Logger.log(`Could not display alert for ${title}: ${e}`);
    }
  }

  try {
    SpreadsheetApp.getActiveSpreadsheet().toast(message, title, toastSeconds);
  } catch (toastErr) {
    Logger.log(`Could not display toast for ${title}: ${toastErr}`);
  }

  Logger.log(`${title}: ${message}`);
}


