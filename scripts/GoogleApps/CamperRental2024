/**
 * Helper functions for distance and duration calculations
 */
function MilesFromHome(address) {
  var directions = Maps.newDirectionFinder()
    .setOrigin('36 Juniper Dr, Amherst, NH')
    .setDestination(address)
    .setMode(Maps.DirectionFinder.Mode.DRIVING)
    .getDirections();

  if (directions && directions.error_message) throw directions.error_message;

  if (
    directions &&
    directions.routes &&
    directions.routes[0] &&
    directions.routes[0].legs &&
    directions.routes[0].legs[0] &&
    directions.routes[0].legs[0].distance
  ) {
    var distanceInMeters = directions.routes[0].legs[0].distance.value;
    return metersToMiles(distanceInMeters);
  }

  return "unknown";
}

function HoursFromHome(address) {
  var directions = Maps.newDirectionFinder()
    .setOrigin('36 Juniper Dr., Amherst, NH')
    .setDestination(address)
    .setMode(Maps.DirectionFinder.Mode.DRIVING)
    .getDirections();

  if (directions && directions.error_message) throw directions.error_message;

  if (
    directions &&
    directions.routes &&
    directions.routes[0] &&
    directions.routes[0].legs &&
    directions.routes[0].legs[0]
  ) {
    return directions.routes[0].legs[0].duration.text;
  }

  return "unknown";
}

function metersToMiles(meters) {
  if (typeof meters !== 'number') return null;
  return meters / 1000 * 0.621371;
}

/**
 * Email helper functions
 */
function getFirstName_(fullName) {
  return String(fullName || "").trim().split(/\s+/)[0] || "";
}

function getValueNextToLabel_(sheet, label) {
  const cell = sheet.createTextFinder(label).matchEntireCell(true).findNext();
  if (!cell) return "";
  return sheet.getRange(cell.getRow(), cell.getColumn() + 1).getDisplayValue().trim();
}

function getGoogleDocAsHtml_(docId) {
  const exportUrl = `https://docs.google.com/document/d/${docId}/export?format=html`;

  const response = UrlFetchApp.fetch(exportUrl, {
    headers: {
      Authorization: `Bearer ${ScriptApp.getOAuthToken()}`
    },
    muteHttpExceptions: true
  });

  const responseCode = response.getResponseCode();

  if (responseCode !== 200) {
    throw new Error(`Failed to export email template as HTML. Response code: ${responseCode}`);
  }

  return response.getContentText();
}

function stripHtmlForPlainText_(html) {
  return String(html || "")
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<\/p>/gi, "\n\n")
    .replace(/<[^>]+>/g, "")
    .replace(/&nbsp;/g, " ")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .trim();
}

function createQuoteDraftEmail_(renterEmail, renterName, agreementFile) {
  const EMAIL_TEMPLATE_DOC_NAME = "TemplateQuoteEmail";

  if (!renterEmail) {
    Logger.log("No renter email found. Draft email was not created.");
    return;
  }

  const templateFiles = DriveApp.getFilesByName(EMAIL_TEMPLATE_DOC_NAME);

  if (!templateFiles.hasNext()) {
    Logger.log(`Email template '${EMAIL_TEMPLATE_DOC_NAME}' not found. Draft email was not created.`);
    return;
  }

  const templateFile = templateFiles.next();
  const firstName = getFirstName_(renterName);

  let htmlBody = getGoogleDocAsHtml_(templateFile.getId());

  htmlBody = htmlBody.replace(/&lt;&lt;renter_name&gt;&gt;/g, firstName);
  htmlBody = htmlBody.replace(/<<renter_name>>/g, firstName);

  const plainBody = stripHtmlForPlainText_(htmlBody);

  const subject = "Your Happy Hooker Rentals quote";
  const attachment = agreementFile.getAs(MimeType.PDF);

  GmailApp.createDraft(
    renterEmail,
    subject,
    plainBody,
    {
      htmlBody: htmlBody,
      attachments: [attachment],
      name: "Happy Hooker Rentals"
    }
  );

  Logger.log(`Created formatted draft email for ${renterEmail} using account: ${Session.getActiveUser().getEmail()}`);
}

/**
 * Main function: creates a rental quote doc, adds row to Waiting to Book, creates calendar event, creates draft email
 */
function createQuote() {
  const TEMPLATE_DOC_NAME = "TemplateRentalAgreement";
  const TARGET_SUBFOLDER = "2026";
  const QUOTE_SHEET = "Quote";
  const BOOKING_ID_CELL = "bookingId";
  const RENTER_NAME_CELL = "renterName";
  const DATE_PLACEHOLDER = "{{date}}";
  const WAITING_SHEET = "Waiting to Book";
  const NEXT_BOOKING_RANGE = "nextBookingId";
  const CALENDAR_NAME = "Happy Hooker Rentals";

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const quoteSheet = ss.getSheetByName(QUOTE_SHEET);
  const waitingSheet = ss.getSheetByName(WAITING_SHEET);

  const bookingId = quoteSheet.getRange(BOOKING_ID_CELL).getDisplayValue().trim();
  const renterName = quoteSheet.getRange(RENTER_NAME_CELL).getDisplayValue().trim();
  const renterEmail = getValueNextToLabel_(quoteSheet, "Renter Email");

  if (!bookingId || !renterName) {
    SpreadsheetApp.getUi().alert("Please fill Booking ID and Renter Name before creating a quote.");
    return;
  }

  const files = DriveApp.getFilesByName(TEMPLATE_DOC_NAME);

  if (!files.hasNext()) {
    SpreadsheetApp.getUi().alert(`Template document '${TEMPLATE_DOC_NAME}' not found.`);
    return;
  }

  const templateFile = files.next();
  const safeBooking = bookingId.replace(/\s+/g, "");
  const safeName = renterName.replace(/\s+/g, "");
  const newDocName = `quote-${safeBooking}-${safeName}-RentalAgreement`;

  let parentFolder = templateFile.getParents().hasNext()
    ? templateFile.getParents().next()
    : DriveApp.getRootFolder();

  let targetFolder = parentFolder.getFoldersByName(TARGET_SUBFOLDER).hasNext()
    ? parentFolder.getFoldersByName(TARGET_SUBFOLDER).next()
    : parentFolder.createFolder(TARGET_SUBFOLDER);

  const newFile = templateFile.makeCopy(newDocName, targetFolder);

  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");
  const doc = DocumentApp.openById(newFile.getId());
  const body = doc.getBody();
  const found = body.findText(DATE_PLACEHOLDER);

  if (found) body.replaceText(DATE_PLACEHOLDER, today);

  doc.saveAndClose();

  try {
    createQuoteDraftEmail_(renterEmail, renterName, newFile);
  } catch (e) {
    Logger.log("Draft email error: " + e);
    SpreadsheetApp.getUi().alert(
      "The quote was created, but the draft email was not created.\n\nError: " + e
    );
  }

  const waitingHeaders = waitingSheet.getRange("A1:N1").getValues()[0];
  const quoteData = {};

  waitingHeaders.forEach(header => {
    if (!header) return;
    const cell = quoteSheet.createTextFinder(header).findNext();

    if (cell) {
      const value = quoteSheet.getRange(cell.getRow(), cell.getColumn() + 1).getDisplayValue();
      quoteData[header] = value;
    }
  });

  const finder = waitingSheet.createTextFinder("{{nextQuote}}").findNext();

  if (!finder) {
    SpreadsheetApp.getUi().alert("Cannot find {{nextQuote}} placeholder.");
    return;
  }

  const insertRow = finder.getRow();

  waitingSheet.insertRowBefore(insertRow);

  const newRow = insertRow;

  waitingHeaders.forEach((header, i) => {
    let value = quoteData[header] || "";

    if (header === "Outdoorsy") value = "N";
    if (header === "Quote Date" || header === "Booking Date") value = today;
    if (header === "Booking ID") value = bookingId;

    waitingSheet.getRange(newRow, i + 1).setValue(value);
  });

  const bookCell = waitingSheet.getRange(newRow, 1);
  const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();

  bookCell.clearContent();
  bookCell.setDataValidation(rule);
  bookCell.setValue(false);

  const nextBookingRange = ss.getRangeByName(NEXT_BOOKING_RANGE);

  if (nextBookingRange) {
    nextBookingRange.setValue(Number(nextBookingRange.getValue()) + 1);
  }

  try {
    const camper = quoteData["Camper"] || "";
    const location = quoteData["Location"] || "";
    const startDate = new Date(quoteData["Start Date"]);
    const endDate = new Date(quoteData["End Date"]);
    const expectedIncome = quoteData["Expected Income"] || "";

    if (camper && location && startDate && endDate) {
      let calendar = CalendarApp.getCalendarsByName(CALENDAR_NAME)[0] || CalendarApp.getCalendarById(CALENDAR_NAME);

      if (calendar) {
        const title = `? hold ${camper} @${location} for ${renterName}`;
        const description = `Renter: ${renterName}\nBooking ID: ${bookingId}\nExpected Income: ${expectedIncome}`;

        calendar.createAllDayEvent(
          title,
          startDate,
          new Date(endDate.getTime() + 24 * 60 * 60 * 1000),
          { location, description }
        );
      }
    }
  } catch (e) {
    Logger.log("Calendar error: " + e);
  }

  const fileUrl = newFile.getUrl();
  const html = HtmlService.createHtmlOutput(`<script>
    window.open('${fileUrl}', '_blank');
    google.script.host.close();
  </script>`).setWidth(100).setHeight(50);

  SpreadsheetApp.getUi().showModalDialog(html, `Opening new rental agreement ${newDocName}...`);
}

/**
 * Moves a reservation from Waiting to Book → Bookings and updates calendar
 */
function bookReservation(row) {
  const CALENDAR_NAME = "Happy Hooker Rentals";
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const waitingSheet = ss.getSheetByName("Waiting to Book");
  const bookingsSheet = ss.getSheetByName("Bookings");
  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");

  if (!row) return;

  const nextFinder = bookingsSheet.createTextFinder("{{nextRenter}}").findNext();

  if (!nextFinder) {
    SpreadsheetApp.getUi().alert("Cannot find {{nextRenter}} placeholder in Bookings tab.");
    return;
  }

  const insertRow = nextFinder.getRow();

  bookingsSheet.insertRowBefore(insertRow);

  const newRow = insertRow;
  const placeholderRange = bookingsSheet.getRange(insertRow + 1, 1, 1, bookingsSheet.getLastColumn());

  placeholderRange.copyTo(bookingsSheet.getRange(newRow, 1), { contentsOnly: false });

  const waitingHeaders = waitingSheet.getRange("A1:N1").getValues()[0];
  const bookingsHeaders = bookingsSheet.getRange("A3:U3").getValues()[0];
  const rowValues = waitingSheet.getRange(row, 1, 1, waitingHeaders.length).getValues()[0];

  const waitingData = {};

  waitingHeaders.forEach((header, i) => {
    waitingData[header] = rowValues[i];
  });

  bookingsHeaders.forEach((header, i) => {
    if (waitingData.hasOwnProperty(header)) {
      bookingsSheet.getRange(newRow, i + 1).setValue(waitingData[header]);
    }

    if (header === "Booking Date") {
      bookingsSheet.getRange(newRow, i + 1).setValue(today);
    }
  });

  waitingSheet.deleteRow(row);

  try {
    const camper = waitingData["Camper"];
    const location = waitingData["Location"];
    const renterName = waitingData["Renter Name"];
    const titleHold = `? hold ${camper} @${location} for ${renterName}`;
    const titleBooked = `${camper} @${location} for ${renterName}`;

    let calendar = CalendarApp.getCalendarsByName(CALENDAR_NAME)[0] || CalendarApp.getCalendarById(CALENDAR_NAME);

    if (!calendar) throw new Error(`Calendar '${CALENDAR_NAME}' not found.`);

    const startDate = new Date(waitingData["Start Date"]);
    const endDate = new Date(waitingData["End Date"]);

    for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
      const events = calendar.getEventsForDay(new Date(d));

      for (const ev of events) {
        if (ev.getTitle().trim() === titleHold.trim()) {
          ev.setTitle(titleBooked);
          Logger.log(`Updated calendar event: '${titleHold}' → '${titleBooked}'`);
        }
      }
    }
  } catch(e) {
    Logger.log("Calendar update error: " + e);
  }

  try {
    const QUOTE_FOLDER_ID = "1-uRn7J6lDS9D6Xa7SH6QJb1TOXdg4DlJ";

    const bookingId = String(waitingData["Booking ID"] || "").trim();
    const renterName = String(waitingData["Renter Name"] || "").trim();

    const safeBooking = bookingId.replace(/\s+/g, "");
    const safeName = renterName.replace(/\s+/g, "");

    const oldFileName = `quote-${safeBooking}-${safeName}-RentalAgreement`;
    const newFileName = `${safeBooking}-${safeName}-RentalAgreement`;

    const folder = DriveApp.getFolderById(QUOTE_FOLDER_ID);
    const files = folder.getFilesByName(oldFileName);

    if (files.hasNext()) {
      const file = files.next();
      file.setName(newFileName);
      Logger.log(`Renamed file '${oldFileName}' → '${newFileName}'`);
    } else {
      Logger.log(`File '${oldFileName}' not found in quote folder ID ${QUOTE_FOLDER_ID}`);
    }
  } catch (err) {
    Logger.log("Error renaming quote file: " + err);
  }

  SpreadsheetApp.getUi().alert(`Reservation for ${waitingData["Renter Name"]} has been booked.`);
}

/**
 * Installable onEdit trigger to handle Book checkbox clicks
 */
function onEditHandler(e) {
  try {
    const range = e.range;
    const sheet = range.getSheet();

    if (!sheet) return;
    if (sheet.getName() !== "Waiting to Book") return;

    const editedRow = range.getRow();
    const editedCol = range.getColumn();

    if (editedCol !== 1) return;
    if (e.value !== "TRUE") return;

    const ui = SpreadsheetApp.getUi();
    const response = ui.alert("Confirm Booking", `Move booking in row ${editedRow} to Bookings?`, ui.ButtonSet.YES_NO);

    if (response !== ui.Button.YES) {
      sheet.getRange(editedRow, 1).setValue(false);
      return;
    }

    bookReservation(editedRow);
  } catch(err) {
    Logger.log("onEditHandler error: " + err);
  }
}

/**
 * One-time setup to create installable onEdit trigger
 */
function setupOnEditTrigger() {
  const ss = SpreadsheetApp.getActive();
  const triggers = ScriptApp.getProjectTriggers();

  for (const t of triggers) {
    if (t.getHandlerFunction() === "onEditHandler") return;
  }

  ScriptApp.newTrigger("onEditHandler").forSpreadsheet(ss).onEdit().create();
}
