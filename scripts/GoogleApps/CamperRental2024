/**
 * Helper functions for distance and duration calculations
 */
function MilesFromHome(address) {
  var directions = Maps.newDirectionFinder()
    .setOrigin('36 Juniper Dr, Amherst, NH')
    .setDestination(address)
    .setMode(Maps.DirectionFinder.Mode.DRIVING)
    .getDirections();
  if (directions && directions.error_message) throw directions.error_message;
  if (directions && directions.routes && directions.routes[0] && directions.routes[0].legs && directions.routes[0].legs[0] && directions.routes[0].legs[0].distance)
    distanceInMeters = directions.routes[0].legs[0].distance.value;
    return metersToMiles(distanceInMeters);
  return "unknown";
}

function HoursFromHome(address) {
  var directions = Maps.newDirectionFinder()
    .setOrigin('36 Juniper Dr., Amherst, NH')
    .setDestination(address)
    .setMode(Maps.DirectionFinder.Mode.DRIVING)
    .getDirections();
  if (directions && directions.error_message) throw directions.error_message;
  if (directions && directions.routes && directions.routes[0] && directions.routes[0].legs && directions.routes[0].legs[0])
    return directions.routes[0].legs[0].duration.text;
  return "unknown";
}

function metersToMiles(meters) {
  if (typeof meters !== 'number') return null;
  return meters / 1000 * 0.621371;
}

/**
 * Main function: creates a rental quote doc, adds row to Waiting to Book, creates calendar event
 */
function createQuote() {
  // CONFIGURATION
  const TEMPLATE_DOC_NAME = "TemplateRentalAgreement";
  const TARGET_SUBFOLDER = "2026";
  const QUOTE_SHEET = "Quote";
  const BOOKING_ID_CELL = "bookingId";
  const RENTER_NAME_CELL = "renterName";
  const DATE_PLACEHOLDER = "{{date}}";
  const WAITING_SHEET = "Waiting to Book";
  const NEXT_BOOKING_RANGE = "nextBookingId";
  const CALENDAR_NAME = "Happy Hooker Rentals";

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const quoteSheet = ss.getSheetByName(QUOTE_SHEET);
  const waitingSheet = ss.getSheetByName(WAITING_SHEET);

  // STEP 1: Read booking info
  const bookingId = quoteSheet.getRange(BOOKING_ID_CELL).getDisplayValue().trim();
  const renterName = quoteSheet.getRange(RENTER_NAME_CELL).getDisplayValue().trim();
  if (!bookingId || !renterName) {
    SpreadsheetApp.getUi().alert("Please fill Booking ID and Renter Name before creating a quote.");
    return;
  }

  // STEP 2: Copy template doc
  const files = DriveApp.getFilesByName(TEMPLATE_DOC_NAME);
  if (!files.hasNext()) {
    SpreadsheetApp.getUi().alert(`Template document '${TEMPLATE_DOC_NAME}' not found.`);
    return;
  }
  const templateFile = files.next();
  const safeBooking = bookingId.replace(/\s+/g, "");
  const safeName = renterName.replace(/\s+/g, "");
  const newDocName = `quote-${safeBooking}-${safeName}-RentalAgreement`;

  let parentFolder = templateFile.getParents().hasNext() ? templateFile.getParents().next() : DriveApp.getRootFolder();
  let targetFolder = parentFolder.getFoldersByName(TARGET_SUBFOLDER).hasNext() 
                     ? parentFolder.getFoldersByName(TARGET_SUBFOLDER).next() 
                     : parentFolder.createFolder(TARGET_SUBFOLDER);

  const newFile = templateFile.makeCopy(newDocName, targetFolder);

  // STEP 3: Update date in doc
  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");
  const doc = DocumentApp.openById(newFile.getId());
  const body = doc.getBody();
  const found = body.findText(DATE_PLACEHOLDER);
  if (found) body.replaceText(DATE_PLACEHOLDER, today);
  doc.saveAndClose();

  // STEP 4: Append to Waiting to Book
  const waitingHeaders = waitingSheet.getRange("A1:N1").getValues()[0];
  const quoteData = {};
  waitingHeaders.forEach(header => {
    if (!header) return;
    const cell = quoteSheet.createTextFinder(header).findNext();
    if (cell) {
      const value = quoteSheet.getRange(cell.getRow(), cell.getColumn() + 1).getDisplayValue();
      quoteData[header] = value;
    }
  });

  const finder = waitingSheet.createTextFinder("{{nextQuote}}").findNext();
  if (!finder) {
    SpreadsheetApp.getUi().alert("Cannot find {{nextQuote}} placeholder.");
    return;
  }
  const insertRow = finder.getRow();
  waitingSheet.insertRowBefore(insertRow);
  const newRow = insertRow;

  waitingHeaders.forEach((header, i) => {
    let value = quoteData[header] || "";
    if (header === "Outdoorsy") value = "N";
    if (header === "Quote Date" || header === "Booking Date") value = today;
    if (header === "Booking ID") value = bookingId;
    waitingSheet.getRange(newRow, i + 1).setValue(value);
  });

  // STEP 5: Add Book checkbox + label
  const bookCell = waitingSheet.getRange(newRow, 1);
  const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
  bookCell.clearContent();
  bookCell.setDataValidation(rule);
  bookCell.setValue(false);

  // STEP 6: Increment nextBookingId
  const nextBookingRange = ss.getRangeByName(NEXT_BOOKING_RANGE);
  if (nextBookingRange) nextBookingRange.setValue(Number(nextBookingRange.getValue()) + 1);

  // STEP 7: Create Google Calendar event
  try {
    const camper = quoteData["Camper"] || "";
    const location = quoteData["Location"] || "";
    const startDate = new Date(quoteData["Start Date"]);
    const endDate = new Date(quoteData["End Date"]);
    const expectedIncome = quoteData["Expected Income"] || "";

    if (camper && location && startDate && endDate) {
      let calendar = CalendarApp.getCalendarsByName(CALENDAR_NAME)[0] || CalendarApp.getCalendarById(CALENDAR_NAME);
      if (calendar) {
        const title = `? hold ${camper} @${location} for ${renterName}`;
        const description = `Renter: ${renterName}\nBooking ID: ${bookingId}\nExpected Income: ${expectedIncome}`;
        calendar.createAllDayEvent(title, startDate, new Date(endDate.getTime() + 24*60*60*1000), {location, description});
      }
    }
  } catch (e) {
    Logger.log("Calendar error: " + e);
  }

  // STEP 8: Open doc
  const fileUrl = newFile.getUrl();
  const html = HtmlService.createHtmlOutput(`<script>
    window.open('${fileUrl}', '_blank');
    google.script.host.close();
  </script>`).setWidth(100).setHeight(50);
  SpreadsheetApp.getUi().showModalDialog(html, `Opening new rental agreement ${newDocName}...`);
}

/**
 * Moves a reservation from Waiting to Book → Bookings and updates calendar
 */
function bookReservation(row) {
  const CALENDAR_NAME = "Happy Hooker Rentals";
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const waitingSheet = ss.getSheetByName("Waiting to Book");
  const bookingsSheet = ss.getSheetByName("Bookings");
  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");

  if (!row) return;

  // STEP 1: Find the {{nextRenter}} placeholder in Bookings
  const nextFinder = bookingsSheet.createTextFinder("{{nextRenter}}").findNext();
  if (!nextFinder) {
    SpreadsheetApp.getUi().alert("Cannot find {{nextRenter}} placeholder in Bookings tab.");
    return;
  }
  const insertRow = nextFinder.getRow();

  // STEP 2: Insert new row above placeholder and copy formulas/format from {{nextRenter}} row
  bookingsSheet.insertRowBefore(insertRow);
  const newRow = insertRow;
  const placeholderRange = bookingsSheet.getRange(insertRow + 1, 1, 1, bookingsSheet.getLastColumn());
  placeholderRange.copyTo(bookingsSheet.getRange(newRow, 1), { contentsOnly: false });

  // STEP 3: Move only matching header values from Waiting to Book → Bookings
  const waitingHeaders = waitingSheet.getRange("A1:N1").getValues()[0];
  const bookingsHeaders = bookingsSheet.getRange("A3:U3").getValues()[0]; // extend to all columns in Bookings
  const rowValues = waitingSheet.getRange(row, 1, 1, waitingHeaders.length).getValues()[0];

  const waitingData = {};
  waitingHeaders.forEach((header, i) => {
    waitingData[header] = rowValues[i];
  });

  bookingsHeaders.forEach((header, i) => {
    if (waitingData.hasOwnProperty(header)) {
      bookingsSheet.getRange(newRow, i + 1).setValue(waitingData[header]);
    }
    // update the Booking Date to today
    if (header === "Booking Date") {
      bookingsSheet.getRange(newRow, i + 1).setValue(today);
    }
  });

  // STEP 4: Delete the old row from Waiting to Book
  waitingSheet.deleteRow(row);

  // --- STEP 5: Update the related calendar event ---
  try {
    const camper = waitingData["Camper"];
    const location = waitingData["Location"];
    const renterName = waitingData["Renter Name"];
    const titleHold = `? hold ${camper} @${location} for ${renterName}`;
    const titleBooked = `${camper} @${location} for ${renterName}`;

    let calendar = CalendarApp.getCalendarsByName(CALENDAR_NAME)[0] || CalendarApp.getCalendarById(CALENDAR_NAME);
    if (!calendar) throw new Error(`Calendar '${CALENDAR_NAME}' not found.`);

    const startDate = new Date(waitingData["Start Date"]);
    const endDate = new Date(waitingData["End Date"]);
    
    // get all events for each day in the range
    for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
      const events = calendar.getEventsForDay(new Date(d));
      for (const ev of events) {
        if (ev.getTitle().trim() === titleHold.trim()) {
          ev.setTitle(titleBooked);
          Logger.log(`Updated calendar event: '${titleHold}' → '${titleBooked}'`);
        }
      }
    }
  } catch(e) {
    Logger.log("Calendar update error: " + e);
  }
  // --- STEP 6: Rename the Google Doc/Sheet for this quote ---
  try {
    const QUOTE_FOLDER_ID = "1-uRn7J6lDS9D6Xa7SH6QJb1TOXdg4DlJ";

    const bookingId = String(waitingData["Booking ID"] || "").trim();
    const renterName = String(waitingData["Renter Name"] || "").trim();

    const safeBooking = bookingId.replace(/\s+/g, "");
    const safeName = renterName.replace(/\s+/g, "");

    const oldFileName = `quote-${safeBooking}-${safeName}-RentalAgreement`;
    const newFileName = `${safeBooking}-${safeName}-RentalAgreement`;

    const folder = DriveApp.getFolderById(QUOTE_FOLDER_ID);
    const files = folder.getFilesByName(oldFileName);

    if (files.hasNext()) {
      const file = files.next();
      file.setName(newFileName);
      Logger.log(`Renamed file '${oldFileName}' → '${newFileName}'`);
    } else {
      Logger.log(`File '${oldFileName}' not found in quote folder ID ${QUOTE_FOLDER_ID}`);
    }
  } catch (err) {
    Logger.log("Error renaming quote file: " + err);
  }

  SpreadsheetApp.getUi().alert(`Reservation for ${waitingData["Renter Name"]} has been booked.`);
}



/**
 * Invoice configuration and helper functions
 */
const INVOICE_TEMPLATE_NAME = "TemplateInvoice-2026";
const QUOTE_FOLDER_ID = "1-uRn7J6lDS9D6Xa7SH6QJb1TOXdg4DlJ";
const BOOKINGS_SHEET_NAME = "Bookings";
const INCOME_SHEET_NAME = "Income";
const INVOICE_COLUMN_HEADER = "Invoice";

function getColumnByHeader_(sheet, headerRow, headerName) {
  const headers = sheet.getRange(headerRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

  for (let i = 0; i < headers.length; i++) {
    if (String(headers[i]).trim() === headerName) {
      return i + 1;
    }
  }

  return null;
}

function getRowDataByHeaders_(sheet, headerRow, dataRow) {
  const headers = sheet.getRange(headerRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];
  const values = sheet.getRange(dataRow, 1, 1, sheet.getLastColumn()).getDisplayValues()[0];

  const data = {};

  headers.forEach((header, i) => {
    if (header) data[String(header).trim()] = values[i];
  });

  return data;
}

function safeNoSpaces_(value) {
  return String(value || "").trim().replace(/\s+/g, "");
}

function parseMoney_(value) {
  const cleaned = String(value || "").replace(/[^0-9.-]/g, "");
  const num = Number(cleaned);
  return isNaN(num) ? 0 : num;
}

function formatMoney_(value) {
  return "$" + Number(value || 0).toFixed(2);
}

function findRentalAgreementFile_(bookingId, renterName) {
  const folder = DriveApp.getFolderById(QUOTE_FOLDER_ID);
  const safeBooking = safeNoSpaces_(bookingId);
  const safeName = safeNoSpaces_(renterName);

  const fileName = `${safeBooking}-${safeName}-RentalAgreement`;
  const files = folder.getFilesByName(fileName);

  if (files.hasNext()) return files.next();

  throw new Error(`Rental agreement not found: ${fileName}`);
}

function createInvoiceFromTemplate_(bookingId, renterName) {
  const templateFiles = DriveApp.getFilesByName(INVOICE_TEMPLATE_NAME);

  if (!templateFiles.hasNext()) {
    throw new Error(`Invoice template '${INVOICE_TEMPLATE_NAME}' not found.`);
  }

  const templateFile = templateFiles.next();
  const folder = DriveApp.getFolderById(QUOTE_FOLDER_ID);

  const safeBooking = safeNoSpaces_(bookingId);
  const safeName = safeNoSpaces_(renterName);
  const invoiceName = `${safeBooking}-${safeName}-Invoice`;

  const newFile = templateFile.makeCopy(invoiceName, folder);

  return {
    file: newFile,
    name: invoiceName
  };
}

function normalizeAgreementKey_(key) {
  return String(key || "")
    .replace(/[:]/g, "")
    .replace(/\s+/g, "")
    .toLowerCase()
    .trim();
}

function extractFieldsFromAgreementDoc_(docFile) {
  const doc = DocumentApp.openById(docFile.getId());
  const body = doc.getBody();
  const fields = {};

  const tables = body.getTables();

  tables.forEach(table => {
    for (let r = 0; r < table.getNumRows(); r++) {
      const row = table.getRow(r);

      if (row.getNumCells() >= 2) {
        const label = row.getCell(0).getText().trim();
        const value = row.getCell(1).getText().trim();

        if (label && value) {
          fields[normalizeAgreementKey_(label)] = value;
        }
      }
    }
  });

  const text = body.getText();
  const lines = text.split(/\r?\n/);

  lines.forEach(line => {
    const match = line.match(/^(.+?)\s*:\s*(.+)$/);

    if (match) {
      const label = match[1].trim();
      const value = match[2].trim();

      if (label && value) {
        fields[normalizeAgreementKey_(label)] = value;
      }
    }
  });

  return fields;
}

function getAgreementValue_(agreementFields, possibleNames) {
  for (const name of possibleNames) {
    const key = normalizeAgreementKey_(name);
    if (agreementFields[key] !== undefined && String(agreementFields[key]).trim() !== "") {
      return agreementFields[key];
    }
  }

  return "";
}

function getPaymentsForBooking_(ss, bookingId) {
  const incomeSheet = ss.getSheetByName(INCOME_SHEET_NAME);

  if (!incomeSheet) {
    throw new Error(`Income sheet '${INCOME_SHEET_NAME}' not found.`);
  }

  const headers = incomeSheet.getRange(1, 1, 1, incomeSheet.getLastColumn()).getDisplayValues()[0];

  const bookingIdCol = headers.findIndex(h => String(h).trim() === "Booking ID") + 1;
  const descriptionCol = headers.findIndex(h => String(h).trim() === "Description") + 1;
  const dateCol = headers.findIndex(h => String(h).trim() === "Date") + 1;
  const amountCol = headers.findIndex(h => String(h).trim() === "Amount") + 1;

  if (!bookingIdCol || !descriptionCol || !dateCol || !amountCol) {
    throw new Error("Income sheet must have headers: Booking ID, Description, Date, Amount.");
  }

  const lastRow = incomeSheet.getLastRow();
  if (lastRow < 2) {
    return {
      descriptions: "",
      dates: "",
      amounts: "",
      totalPaid: 0,
      count: 0
    };
  }

  const rows = incomeSheet.getRange(2, 1, lastRow - 1, incomeSheet.getLastColumn()).getDisplayValues();

  const matched = [];
  let totalPaid = 0;

  rows.forEach(row => {
    const rowBookingId = String(row[bookingIdCol - 1]).trim();

    if (rowBookingId === String(bookingId).trim()) {
      const description = row[descriptionCol - 1];
      const date = row[dateCol - 1];
      const amountRaw = row[amountCol - 1];
      const amount = parseMoney_(amountRaw);

      totalPaid += amount;

      matched.push({
        description,
        date,
        amountDisplay: formatMoney_(amount),
        amount
      });
    }
  });

  return {
    descriptions: matched.map(p => p.description).join("\n"),
    dates: matched.map(p => p.date).join("\n"),
    amounts: matched.map(p => p.amountDisplay).join("\n"),
    totalPaid,
    count: matched.length
  };
}

function replaceInvoicePlaceholders_(spreadsheetFile, mergeValues) {
  const invoiceSs = SpreadsheetApp.openById(spreadsheetFile.getId());

  invoiceSs.getSheets().forEach(sheet => {
    Object.keys(mergeValues).forEach(key => {
      const placeholder = `<<${key}>>`;
      const value = String(mergeValues[key] ?? "");

      sheet.createTextFinder(placeholder).replaceAllWith(value);
    });
  });

  SpreadsheetApp.flush();
}

/**
 * Run manually once after adding the Invoice column, or whenever you need to restore invoice checkboxes.
 */
function setupInvoiceColumn() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const bookingsSheet = ss.getSheetByName(BOOKINGS_SHEET_NAME);
  const headerRow = 3;

  if (!bookingsSheet) {
    SpreadsheetApp.getUi().alert(`Sheet '${BOOKINGS_SHEET_NAME}' not found.`);
    return;
  }

  let invoiceCol = getColumnByHeader_(bookingsSheet, headerRow, INVOICE_COLUMN_HEADER);

  if (!invoiceCol) {
    invoiceCol = bookingsSheet.getLastColumn() + 1;
    bookingsSheet.getRange(headerRow, invoiceCol).setValue(INVOICE_COLUMN_HEADER);
  }

  const lastRow = bookingsSheet.getLastRow();

  if (lastRow <= headerRow) {
    SpreadsheetApp.getUi().alert("Invoice column created. No booking rows found yet.");
    return;
  }

  const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
  const checkboxRange = bookingsSheet.getRange(headerRow + 1, invoiceCol, lastRow - headerRow, 1);

  checkboxRange.setDataValidation(rule);

  SpreadsheetApp.getUi().alert(`Invoice column is ready in column ${invoiceCol}.`);
}

function generateInvoice(row) {
  const statusLog = [];
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const bookingsSheet = ss.getSheetByName(BOOKINGS_SHEET_NAME);
  const headerRow = 3;

  try {
    if (!bookingsSheet) {
      throw new Error(`Sheet '${BOOKINGS_SHEET_NAME}' not found.`);
    }

    const bookingData = getRowDataByHeaders_(bookingsSheet, headerRow, row);

    const bookingId = bookingData["Booking ID"];
    const renterName = bookingData["Renter Name"];

    if (!bookingId || !renterName) {
      throw new Error("Booking ID or Renter Name missing from selected Bookings row.");
    }

    addStatus_(statusLog, "Invoice setup", true, `Booking ${bookingId} for ${renterName}.`);

    const agreementFile = findRentalAgreementFile_(bookingId, renterName);
    addStatus_(statusLog, "Rental agreement", true, `Found ${agreementFile.getName()}.`);

    const agreementFields = extractFieldsFromAgreementDoc_(agreementFile);
    addStatus_(statusLog, "Agreement data", true, "Extracted label/value fields from rental agreement.");

    const paymentData = getPaymentsForBooking_(ss, bookingId);
    addStatus_(statusLog, "Payments", true, `Found ${paymentData.count} payment row(s). Total paid: ${formatMoney_(paymentData.totalPaid)}.`);

    const invoice = createInvoiceFromTemplate_(bookingId, renterName);
    addStatus_(statusLog, "Invoice file", true, `Created ${invoice.name}.`);

    const totalCostRaw =
      getAgreementValue_(agreementFields, ["totalCost", "Total Cost", "Total Rental Cost", "Expected Income"]) ||
      bookingData["Expected Income"] ||
      bookingData["Total Cost"] ||
      "0";

    const totalCost = parseMoney_(totalCostRaw);
    const balance = totalCost - paymentData.totalPaid;

    const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");

    const mergeValues = {
      bookingId: bookingId,
      renterName: renterName,
      renterNameNoSpaces: safeNoSpaces_(renterName),

      paymentDescriptions: paymentData.descriptions,
      paymentDates: paymentData.dates,
      payments: paymentData.amounts,

      totalPaid: formatMoney_(paymentData.totalPaid),
      totalCost: formatMoney_(totalCost),
      balance: formatMoney_(balance),

      invoiceDate: today,
      today: today
    };

    Object.keys(bookingData).forEach(key => {
      const cleanKey = key.replace(/\s+/g, "");
      if (!mergeValues[cleanKey]) mergeValues[cleanKey] = bookingData[key];
    });

    Object.keys(agreementFields).forEach(key => {
      if (!mergeValues[key]) mergeValues[key] = agreementFields[key];
    });

    replaceInvoicePlaceholders_(invoice.file, mergeValues);
    addStatus_(statusLog, "Invoice merge", true, "Replaced invoice placeholders.");

    const invoiceUrl = invoice.file.getUrl();

    showStatusLog_("Invoice Status", statusLog);

    const html = HtmlService.createHtmlOutput(`<script>
      window.open('${invoiceUrl}', '_blank');
      google.script.host.close();
    </script>`).setWidth(100).setHeight(50);

    SpreadsheetApp.getUi().showModalDialog(html, `Opening invoice ${invoice.name}...`);
  } catch (e) {
    addStatus_(statusLog, "Invoice error", false, e.toString());
    showStatusLog_("Invoice Status", statusLog);
    Logger.log("generateInvoice error: " + e);
  }
}

/**
 * Installable onEdit trigger to handle:
 * 1. Book checkbox clicks on Waiting to Book
 * 2. Invoice checkbox clicks on Bookings
 */
function onEditHandler(e) {
  try {
    const range = e.range;
    const sheet = range.getSheet();

    if (!sheet) return;

    const sheetName = sheet.getName();
    const editedRow = range.getRow();
    const editedCol = range.getColumn();

    if (e.value !== "TRUE") return;

    const ui = SpreadsheetApp.getUi();

    // Existing Book workflow
    if (sheetName === "Waiting to Book") {
      if (editedCol !== 1) return;

      const response = ui.alert("Confirm Booking", `Move booking in row ${editedRow} to Bookings?`, ui.ButtonSet.YES_NO);

      if (response !== ui.Button.YES) {
        sheet.getRange(editedRow, 1).setValue(false);
        return;
      }

      bookReservation(editedRow);
      return;
    }

    // New Invoice workflow
    if (sheetName === BOOKINGS_SHEET_NAME) {
      const invoiceCol = getColumnByHeader_(sheet, 3, INVOICE_COLUMN_HEADER);

      if (!invoiceCol || editedCol !== invoiceCol) return;
      if (editedRow <= 3) return;

      const response = ui.alert("Confirm Invoice", `Create invoice for booking row ${editedRow}?`, ui.ButtonSet.YES_NO);

      if (response !== ui.Button.YES) {
        sheet.getRange(editedRow, editedCol).setValue(false);
        return;
      }

      generateInvoice(editedRow);
      return;
    }
  } catch(err) {
    Logger.log("onEditHandler error: " + err);
  }
}

/**
 * One-time setup to create installable onEdit trigger
 */
function setupOnEditTrigger() {
  const ss = SpreadsheetApp.getActive();
  const triggers = ScriptApp.getProjectTriggers();
  for (const t of triggers) {
    if (t.getHandlerFunction() === "onEditHandler") return;
  }
  ScriptApp.newTrigger("onEditHandler").forSpreadsheet(ss).onEdit().create();
}
