function getPreferredDraftFromAddress_() {
  const activeEmail = Session.getActiveUser().getEmail();
  if (String(activeEmail || "").toLowerCase() === HHR_EMAIL_ADDRESS.toLowerCase()) {
    return HHR_EMAIL_ADDRESS;
  }

  const aliases = GmailApp.getAliases().map(alias => String(alias || "").toLowerCase());
  if (aliases.includes(HHR_EMAIL_ADDRESS.toLowerCase())) {
    return HHR_EMAIL_ADDRESS;
  }

  return "";
}

function isUsableRecipientEmail_(value) {
  const normalizedEmail = normalizeContactValue_(value);
  if (!normalizedEmail) return false;
  if (normalizedEmail === "outdoorsy" || normalizedEmail === "n/a") return false;
  if (normalizedEmail === normalizeContactValue_(HHR_EMAIL_ADDRESS)) return false;
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(normalizedEmail);
}

function createSelectedContactsEmail() {
  const contactsSheet = getContactsSheet_();
  const nextCell = findExactCell_(contactsSheet, "{{next}}");

  if (!nextCell) {
    SpreadsheetApp.getUi().alert("Create Email", `Cannot find {{next}} placeholder in '${CONTACTS_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const headers = contactsSheet.getRange(CONTACTS_HEADER_ROW, 1, 1, contactsSheet.getLastColumn()).getDisplayValues()[0];
  const emailCol = getColumnIndexByHeaderName_(headers, "Renter Email");
  if (!emailCol) {
    SpreadsheetApp.getUi().alert("Create Email", `Column 'Renter Email' not found in '${CONTACTS_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const dataRowCount = nextCell.getRow() - CONTACTS_FIRST_DATA_ROW;
  if (dataRowCount <= 0) {
    SpreadsheetApp.getUi().alert("Create Email", `No renter rows found in '${CONTACTS_SHEET_NAME}'.`, SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const values = contactsSheet.getRange(CONTACTS_FIRST_DATA_ROW, 1, dataRowCount, contactsSheet.getLastColumn()).getDisplayValues();
  const selectedEmails = [];
  const seenEmails = {};
  let selectedCount = 0;

  values.forEach(rowValues => {
    const isSelected = String(rowValues[CONTACTS_SELECT_COLUMN - 1] || "").toUpperCase() === "TRUE";
    if (!isSelected) return;

    selectedCount++;
    const renterEmail = String(rowValues[emailCol - 1] || "").trim();
    if (!isUsableRecipientEmail_(renterEmail)) return;

    const normalizedEmail = renterEmail.toLowerCase();
    if (seenEmails[normalizedEmail]) return;
    seenEmails[normalizedEmail] = true;
    selectedEmails.push(renterEmail);
  });

  if (!selectedCount) {
    SpreadsheetApp.getUi().alert("Create Email", "No renters are selected.", SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  if (!selectedEmails.length) {
    clearAllContactSelections_(contactsSheet);
    SpreadsheetApp.getUi().alert("Create Email", "Selected renters did not have any email addresses.", SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  const draftFrom = getPreferredDraftFromAddress_();
  const draftTo = draftFrom || Session.getActiveUser().getEmail();
  const options = {
    bcc: selectedEmails.join(","),
    name: "Happy Hooker Rentals"
  };

  if (draftFrom) {
    options.from = draftFrom;
  }

  GmailApp.createDraft(
    draftTo,
    CONTACTS_EMAIL_DRAFT_SUBJECT,
    "",
    options
  );

  clearAllContactSelections_(contactsSheet);

  SpreadsheetApp.getUi().alert(
    "Create Email",
    `A draft email is created in ${draftTo} to ${selectedEmails.length} recipients that were selected.`,
    SpreadsheetApp.getUi().ButtonSet.OK
  );
}

function escapeHtml_(text) {
  return String(text || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function wrapHtmlTextSegment_(text, attributes) {
  let html = escapeHtml_(text).replace(/\r?\n/g, "<br>");
  if (!attributes) return html;

  if (attributes.LINK_URL) {
    html = `<a href="${escapeHtml_(attributes.LINK_URL)}">${html}</a>`;
  }
  if (attributes.UNDERLINE) {
    html = `<u>${html}</u>`;
  }
  if (attributes.ITALIC) {
    html = `<em>${html}</em>`;
  }
  if (attributes.BOLD) {
    html = `<strong>${html}</strong>`;
  }

  return html;
}

function getRichTextElementHtml_(textElement) {
  const text = textElement.getText();
  if (!text) return "";

  const attributeStarts = textElement.getTextAttributeIndices();
  const htmlParts = [];

  attributeStarts.forEach((start, index) => {
    const end = index + 1 < attributeStarts.length ? attributeStarts[index + 1] - 1 : text.length - 1;
    const segmentText = text.slice(start, end + 1);
    const attributes = textElement.getAttributes(start);
    htmlParts.push(wrapHtmlTextSegment_(segmentText, attributes));
  });

  return htmlParts.join("");
}

function getParagraphTagName_(paragraph) {
  const heading = paragraph.getHeading();
  switch (heading) {
    case DocumentApp.ParagraphHeading.HEADING1:
    case DocumentApp.ParagraphHeading.TITLE:
      return "h1";
    case DocumentApp.ParagraphHeading.HEADING2:
    case DocumentApp.ParagraphHeading.SUBTITLE:
      return "h2";
    case DocumentApp.ParagraphHeading.HEADING3:
      return "h3";
    case DocumentApp.ParagraphHeading.HEADING4:
      return "h4";
    case DocumentApp.ParagraphHeading.HEADING5:
      return "h5";
    case DocumentApp.ParagraphHeading.HEADING6:
      return "h6";
    default:
      return "p";
  }
}

function getParagraphInnerHtml_(paragraph) {
  const htmlParts = [];

  for (let i = 0; i < paragraph.getNumChildren(); i++) {
    const child = paragraph.getChild(i);
    const childType = child.getType();

    if (childType === DocumentApp.ElementType.TEXT) {
      htmlParts.push(getRichTextElementHtml_(child.asText()));
      continue;
    }

    if (childType === DocumentApp.ElementType.INLINE_IMAGE) {
      continue;
    }

    if (childType === DocumentApp.ElementType.PAGE_BREAK) {
      htmlParts.push("<br>");
    }
  }

  return htmlParts.join("");
}

function getGoogleDocAsHtml_(docId) {
  const doc = DocumentApp.openById(docId);
  const body = doc.getBody();
  const htmlParts = [];
  let activeListId = null;

  for (let i = 0; i < body.getNumChildren(); i++) {
    const child = body.getChild(i);
    const childType = child.getType();

    if (childType === DocumentApp.ElementType.PARAGRAPH) {
      if (activeListId) {
        htmlParts.push("</ul>");
        activeListId = null;
      }

      const paragraph = child.asParagraph();
      const innerHtml = getParagraphInnerHtml_(paragraph);
      if (!innerHtml) continue;

      const tagName = getParagraphTagName_(paragraph);
      htmlParts.push(`<${tagName}>${innerHtml}</${tagName}>`);
      continue;
    }

    if (childType === DocumentApp.ElementType.LIST_ITEM) {
      const listItem = child.asListItem();
      const listId = listItem.getListId();

      if (activeListId !== listId) {
        if (activeListId) htmlParts.push("</ul>");
        htmlParts.push("<ul>");
        activeListId = listId;
      }

      const innerHtml = getParagraphInnerHtml_(listItem);
      htmlParts.push(`<li>${innerHtml || "&nbsp;"}</li>`);
      continue;
    }

    if (childType === DocumentApp.ElementType.TABLE) {
      if (activeListId) {
        htmlParts.push("</ul>");
        activeListId = null;
      }

      const table = child.asTable();
      const rows = [];

      for (let r = 0; r < table.getNumRows(); r++) {
        const row = table.getRow(r);
        const cells = [];

        for (let c = 0; c < row.getNumCells(); c++) {
          const cellParagraphs = row.getCell(c).getParagraphs()
            .map(getParagraphInnerHtml_)
            .filter(Boolean)
            .join("<br>");
          cells.push(`<td>${cellParagraphs || "&nbsp;"}</td>`);
        }

        rows.push(`<tr>${cells.join("")}</tr>`);
      }

      htmlParts.push(`<table border="1" cellpadding="6" cellspacing="0">${rows.join("")}</table>`);
    }
  }

  if (activeListId) {
    htmlParts.push("</ul>");
  }

  return htmlParts.join("\n");
}

function stripHtmlForPlainText_(html) {
  return String(html || "")
    .replace(/<style[\s\S]*?<\/style>/gi, "")
    .replace(/<script[\s\S]*?<\/script>/gi, "")
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<\/p>/gi, "\n\n")
    .replace(/<[^>]+>/g, "")
    .replace(/&nbsp;/g, " ")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .trim();
}

function createQuoteDraftEmail_(renterEmail, renterName, agreementFile) {
  if (!renterEmail) {
    throw new Error("No renter email found.");
  }

  const templateFile = getDriveFileByIdOrName_(QUOTE_EMAIL_TEMPLATE_DOC_ID, QUOTE_EMAIL_TEMPLATE_DOC_NAME);
  if (!templateFile) {
    throw new Error(`Email template '${QUOTE_EMAIL_TEMPLATE_DOC_NAME}' not found.`);
  }
  const firstName = getFirstName_(renterName);

  let htmlBody = getGoogleDocAsHtml_(templateFile.getId());
  htmlBody = htmlBody.replace(/&lt;&lt;renter_name&gt;&gt;/g, firstName);
  htmlBody = htmlBody.replace(/<<renter_name>>/g, firstName);

  const plainBody = stripHtmlForPlainText_(htmlBody);
  const subject = "Your Happy Hooker Rentals quote";
  const attachment = agreementFile.getAs(MimeType.PDF);

  GmailApp.createDraft(
    renterEmail,
    subject,
    plainBody,
    {
      htmlBody: htmlBody,
      attachments: [attachment],
      name: "Happy Hooker Rentals"
    }
  );

  return `Created formatted draft for ${renterEmail} using account ${Session.getActiveUser().getEmail()}`;
}

/**
 * Main function: validates quote uniqueness, creates a rental quote doc,
 * updates Contacts, adds a row to Waiting to Book, and creates a calendar event.
 */
function createQuote(options) {
  const statusLog = [];
  const createQuoteOptions = options || {};
  const shouldOpenDocument = createQuoteOptions.openDocument !== false;

  // CONFIGURATION
  const BOOKING_ID_CELL = "bookingId";
  const RENTER_NAME_CELL = "renterName";
  const START_DATE_RANGE_NAME = "startDate";
  const NEXT_BOOKING_RANGE = "nextBookingId";

  const sourceSs = SpreadsheetApp.getActiveSpreadsheet();
  const quoteSheet = sourceSs.getSheetByName(QUOTE_SHEET_NAME);
  const quoteType = getQuoteType_(sourceSs);

  let newFile = null;
  let newDocName = "";
  let bookingId = "";

  try {
    if (!quoteSheet) throw new Error(`Sheet '${QUOTE_SHEET_NAME}' not found.`);

    setQuoteTriggerStatus_("Create Quote is running...", "#fff2cc");

    // STEP 1: Read booking info
    bookingId = quoteSheet.getRange(BOOKING_ID_CELL).getDisplayValue().trim();
    const renterName = quoteSheet.getRange(RENTER_NAME_CELL).getDisplayValue().trim();
    const renterPhone = getNamedRangeDisplayValue_(sourceSs, "renterPhone") || getValueNextToLabel_(quoteSheet, "Renter Phone");
    const renterEmail = getNamedRangeDisplayValue_(sourceSs, "renterEmail") || getValueNextToLabel_(quoteSheet, "Renter Email");
    const camper = getNamedRangeDisplayValue_(sourceSs, "camper") || getValueNextToLabel_(quoteSheet, "Camper");
    const startDateRaw = getNamedRangeDisplayValue_(sourceSs, START_DATE_RANGE_NAME) || getValueNextToLabel_(quoteSheet, "Start Date");
    const endDateRaw = getNamedRangeDisplayValue_(sourceSs, "endDate") || getValueNextToLabel_(quoteSheet, "End Date");
    const workflowContext = getQuoteWorkflowContext_(startDateRaw);
    const ss = workflowContext.spreadsheet;
    ensureSpreadsheetTriggers_(ss);
    const waitingSheet = ss.getSheetByName(WAITING_SHEET_NAME);

    if (!waitingSheet) {
      throw new Error(`Sheet '${WAITING_SHEET_NAME}' not found in '${ss.getName()}'.`);
    }

    if (!bookingId || !renterName) {
      addStatus_(statusLog, "Quote setup", false, "Missing Booking ID or Renter Name.");
      updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
      showStatusLog_("Create Quote Status", statusLog);
      return;
    }

    addStatus_(statusLog, "Quote setup", true, `Booking ${bookingId} for ${renterName}.`);
    addStatus_(
      statusLog,
      "Workflow year",
      true,
      `Using '${ss.getName()}' and folder '${workflowContext.yearFolder.getName()}' for ${workflowContext.year} based on start date '${startDateRaw}'.`
    );

    const quoteStartDate = parseSheetDate_(startDateRaw);
    const quoteEndDate = parseSheetDate_(endDateRaw);
    if (camper && quoteStartDate && quoteEndDate) {
      const conflicts = getQuoteConflicts_(ss, {
        camper: camper,
        startDate: quoteStartDate,
        endDate: quoteEndDate
      });

      conflicts.errors.forEach(message => addStatus_(statusLog, "Conflict guard", false, message));
      conflicts.warnings.forEach(message => addStatus_(statusLog, "Conflict guard", false, message));

      if (conflicts.errors.length) {
        showMessage_(
          "Create Quote Error",
          conflicts.errors.concat(conflicts.warnings).join("\n"),
          { preferToastOnly: true, toastSeconds: 10 }
        );
        updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
        return;
      }

      if (conflicts.warnings.length) {
        showMessage_(
          "Create Quote Warning",
          conflicts.warnings.join("\n"),
          { preferToastOnly: true, toastSeconds: 10 }
        );
      }
    }

    const waitingBookingIdCol = getColumnByHeader_(waitingSheet, 1, "Booking ID");
    if (waitingBookingIdCol) {
      const waitingLastRow = waitingSheet.getLastRow();
      if (waitingLastRow > 1) {
        const waitingBookingIds = waitingSheet.getRange(2, waitingBookingIdCol, waitingLastRow - 1, 1).getDisplayValues();
        const duplicateBooking = waitingBookingIds.some(row => String(row[0] || "").trim() === bookingId);

        if (duplicateBooking) {
          addStatus_(
            statusLog,
            "Quote setup",
            false,
            `A Booking ID for ${renterName} already exists. Cancel existing quote before creating a new one with the same Booking ID`
          );
          updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
          showStatusLog_("Create Quote Status", statusLog);
          return;
        }
      }
    }

    // STEP 2: Copy the rental agreement template into the booking year's folder
    const templateFile = getDriveFileByIdOrName_(QUOTE_TEMPLATE_DOC_ID, QUOTE_TEMPLATE_DOC_NAME);
    if (!templateFile) {
      addStatus_(statusLog, "Template lookup", false, `Template document '${QUOTE_TEMPLATE_DOC_NAME}' not found.`);
      updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
      showStatusLog_("Create Quote Status", statusLog);
      return;
    }

    addStatus_(statusLog, "Template lookup", true, `Found ${QUOTE_TEMPLATE_DOC_NAME}.`);

    const safeBooking = bookingId.replace(/\s+/g, "");
    const safeName = renterName.replace(/\s+/g, "");
    newDocName = `quote-${safeBooking}-${safeName}-RentalAgreement`;

    newFile = templateFile.makeCopy(newDocName, workflowContext.yearFolder);
    addStatus_(statusLog, "Agreement document", true, `Created ${newDocName}.`);

    // STEP 3: Replace <<namedRangeName>> placeholders from the current quote sheet's named ranges
    const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");
    const doc = DocumentApp.openById(newFile.getId());

    const mergeValues = getNamedRangeMergeValues_(sourceSs);
    mergeValues.today = today;
    mergeValues.date = today;
    mergeValues.outdoorsyRentalCost = getNamedRangeDisplayValue_(sourceSs, "outdoorsyTotalCost");

    replaceNamedRangePlaceholders_(doc, mergeValues);
    doc.saveAndClose();

    addStatus_(statusLog, "Template merge", true, "Replaced named-range placeholders in the agreement doc.");

    // STEP 3B: Create draft email after the agreement has been fully merged
    if (quoteType === "Outdoorsy") {
      addStatus_(statusLog, "Email quote skipped", true, "Outdoorsy Quote");
    } else {
      try {
        const draftStatus = createQuoteDraftEmail_(renterEmail, renterName, newFile);
        addStatus_(statusLog, "Draft email", true, draftStatus);
      } catch (e) {
        addStatus_(statusLog, "Draft email", false, e.toString());
      }
    }

    // STEP 3C: Insert renter into Contacts sheet
    try {
      const contactInsert = insertContactRow_(renterName, renterPhone, renterEmail);
      if (contactInsert.wasAdded) {
        addStatus_(
          statusLog,
          "Contacts",
          true,
          `Inserted renter into '${CONTACTS_SHEET_NAME}' row ${contactInsert.row} with Year Added ${contactInsert.yearAdded}.`
        );
      } else {
        addStatus_(
          statusLog,
          "Contacts",
          true,
          `Renter already found in '${CONTACTS_SHEET_NAME}' row ${contactInsert.row}.`
        );
      }
    } catch (e) {
      addStatus_(statusLog, "Contacts", false, e.toString());
    }

    // STEP 4: Append to Waiting to Book
    const waitingHeaders = waitingSheet.getRange(1, 1, 1, waitingSheet.getLastColumn()).getValues()[0];
    const quoteData = {};

    waitingHeaders.forEach(header => {
      if (!header) return;
      const cell = findExactCell_(quoteSheet, header);
      if (cell) {
        const value = quoteSheet.getRange(cell.getRow(), cell.getColumn() + 1).getDisplayValue();
        quoteData[header] = value;
      }
    });

    const finder = findExactCell_(waitingSheet, "{{nextQuote}}");
    if (!finder) {
      addStatus_(statusLog, "Waiting to Book", false, "Cannot find {{nextQuote}} placeholder.");
      updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
      showStatusLog_("Create Quote Status", statusLog);
      return;
    }

    const insertRow = finder.getRow();
    waitingSheet.insertRowBefore(insertRow);
    const newRow = insertRow;
    const bookingStartDateValue = quoteData["Start Date"] || getMergeValue_(mergeValues, ["startDate", "Start Date", "rentalStartDate"]) || "";
    const outdoorsyNextPaymentDate = quoteType === "Outdoorsy" ? addDays_(bookingStartDateValue, 2) : null;
    const directNextPaymentDate = quoteType === "Outdoorsy" ? null : addDays_(bookingStartDateValue, -14);
    const quoteDateDate = parseSheetDate_(today);
    let nextPaymentValue = today;

    if (outdoorsyNextPaymentDate) {
      nextPaymentValue = formatSheetDate_(outdoorsyNextPaymentDate);
    } else if (directNextPaymentDate) {
      nextPaymentValue = directNextPaymentDate < quoteDateDate
        ? today
        : formatSheetDate_(directNextPaymentDate);
    }

    const rowValues = waitingHeaders.map(header => {
      let value = quoteData[header] || "";
      if (header === "Outdoorsy") value = quoteType === "Outdoorsy" ? "Y" : "N";
      if (header === "Quote Date" || header === "Booking Date") value = today;
      if (header === "Booking ID") value = bookingId;
      if (header === "Next Payment") value = nextPaymentValue;
      return value;
    });
    waitingSheet.getRange(newRow, 1, 1, rowValues.length).setValues([rowValues]);

    addStatus_(statusLog, "Waiting to Book", true, `Inserted quote row ${newRow}.`);

    // STEP 5: Add Book checkbox
    const bookCell = waitingSheet.getRange(newRow, 1);
    const rule = SpreadsheetApp.newDataValidation().requireCheckbox().setAllowInvalid(false).build();
    bookCell.clearContent();
    bookCell.setDataValidation(rule);
    bookCell.setValue(false);

    addStatus_(statusLog, "Book checkbox", true, `Added checkbox to row ${newRow}.`);

    // STEP 6: Increment nextBookingId
    const nextBookingRange = ss.getRangeByName(NEXT_BOOKING_RANGE);
    if (nextBookingRange) {
      nextBookingRange.setValue(Number(nextBookingRange.getValue()) + 1);
      addStatus_(statusLog, "Booking ID", true, "Incremented nextBookingId.");
    } else {
      addStatus_(statusLog, "Booking ID", false, `Named range '${NEXT_BOOKING_RANGE}' not found.`);
    }

    // STEP 7: Create Google Calendar hold using Calendar ID when configured
    try {
      const camper = getMergeValue_(mergeValues, ["camper", "Camper"]) || quoteData["Camper"] || "";
      const location = getMergeValue_(mergeValues, ["location", "Location"]) || quoteData["Location"] || "";
      const startDateRaw = getMergeValue_(mergeValues, ["startDate", "Start Date", "rentalStartDate"]) || quoteData["Start Date"] || "";
      const endDateRaw = getMergeValue_(mergeValues, ["endDate", "End Date", "rentalEndDate"]) || quoteData["End Date"] || "";
      const expectedIncome = getMergeValue_(mergeValues, ["expectedIncome", "Expected Income"]) || quoteData["Expected Income"] || "";

      const startDate = parseSheetDate_(startDateRaw);
      const endDate = parseSheetDate_(endDateRaw);

      if (!camper || !location || !startDate || !endDate) {
        addStatus_(
          statusLog,
          "Calendar hold",
          false,
          `Skipped. Camper='${camper}', Location='${location}', Start='${startDateRaw}', End='${endDateRaw}'.`
        );
      } else {
        const calendar = getHhrCalendar_();

        if (!calendar) {
          addStatus_(statusLog, "Calendar hold", false, `Could not find ${getHhrCalendarLookupDescription_()}.`);
        } else {
          const title = `? hold ${camper} @${location} for ${renterName}`;
          const description = `Renter: ${renterName}\nBooking ID: ${bookingId}\nExpected Income: ${expectedIncome}`;

          calendar.createAllDayEvent(
            title,
            startDate,
            new Date(endDate.getTime() + 24 * 60 * 60 * 1000),
            { location, description }
          );

          addStatus_(statusLog, "Calendar hold", true, `Created '${title}'.`);
        }
      }
    } catch (e) {
      addStatus_(statusLog, "Calendar hold", false, e.toString());
    }

    updateQuoteTriggerStatusFromLog_(bookingId, statusLog, false);
    showStatusLog_("Create Quote Status", statusLog);

    // STEP 8: Open doc
    if (newFile && shouldOpenDocument) {
      try {
        const fileUrl = newFile.getUrl();
        const html = HtmlService.createHtmlOutput(`<script>
          window.open('${fileUrl}', '_blank');
          google.script.host.close();
        </script>`).setWidth(100).setHeight(50);
        SpreadsheetApp.getUi().showModalDialog(html, `Opening new rental agreement ${newDocName}...`);
      } catch (uiErr) {
        addStatus_(statusLog, "Open document", false, uiErr.toString());
        updateQuoteTriggerStatusFromLog_(bookingId, statusLog, false);
        Logger.log("createQuote open dialog error: " + uiErr);
      }
    }
  } catch (e) {
    addStatus_(statusLog, "Unexpected error", false, e.toString());
    updateQuoteTriggerStatusFromLog_(bookingId, statusLog, true);
    showStatusLog_("Create Quote Status", statusLog);
    Logger.log("createQuote error: " + e);
  }
}

/**
 * Moves a reservation from Waiting to Book → Bookings and updates calendar
 */
function bookReservation(row, options) {
  const settings = options || {};
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const waitingSheet = ss.getSheetByName("Waiting to Book");
  const bookingsSheet = ss.getSheetByName(BOOKINGS_SHEET_NAME);
  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "MM/dd/yyyy");
  const followUpWarnings = [];

  if (!row) return;
  if (!waitingSheet) throw new Error("Sheet 'Waiting to Book' not found.");
  if (!bookingsSheet) throw new Error(`Sheet '${BOOKINGS_SHEET_NAME}' not found.`);

  // STEP 1: Find the {{nextRenter}} placeholder in Bookings
  const nextFinder = findExactCell_(bookingsSheet, "{{nextRenter}}");
  if (!nextFinder) {
    SpreadsheetApp.getUi().alert("Cannot find {{nextRenter}} placeholder in Bookings tab.");
    return;
  }
  const insertRow = nextFinder.getRow();

  // STEP 2: Insert new row above placeholder and copy formulas/format from {{nextRenter}} row
  bookingsSheet.insertRowBefore(insertRow);
  const newRow = insertRow;
  const placeholderRange = bookingsSheet.getRange(insertRow + 1, 1, 1, bookingsSheet.getLastColumn());
  placeholderRange.copyTo(bookingsSheet.getRange(newRow, 1), { contentsOnly: false });

  // STEP 3: Move only matching header values from Waiting to Book → Bookings
  const waitingHeaders = waitingSheet.getRange(1, 1, 1, waitingSheet.getLastColumn()).getValues()[0];
  const bookingsHeaders = bookingsSheet.getRange(3, 1, 1, bookingsSheet.getLastColumn()).getValues()[0];
  const rowValues = waitingSheet.getRange(row, 1, 1, waitingHeaders.length).getValues()[0];

  const waitingData = {};
  waitingHeaders.forEach((header, i) => {
    waitingData[header] = rowValues[i];
  });

  bookingsHeaders.forEach((header, i) => {
    if (waitingData.hasOwnProperty(header)) {
      bookingsSheet.getRange(newRow, i + 1).setValue(waitingData[header]);
    }
    // update the Booking Date to today
    if (header === "Booking Date") {
      bookingsSheet.getRange(newRow, i + 1).setValue(today);
    }
  });

  // --- STEP 4: Update the related calendar event ---
  try {
    const camper = waitingData["Camper"];
    const location = waitingData["Location"];
    const renterName = waitingData["Renter Name"];
    const titleHold = `? hold ${camper} @${location} for ${renterName}`;
    const titleBooked = `${camper} @${location} for ${renterName}`;

    const calendar = getHhrCalendar_();
    if (!calendar) throw new Error(`Could not find ${getHhrCalendarLookupDescription_()}.`);

    const startDate = new Date(waitingData["Start Date"]);
    const endDate = new Date(waitingData["End Date"]);
    
    // get all events for each day in the range
    for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
      const events = calendar.getEventsForDay(new Date(d));
      for (const ev of events) {
        if (ev.getTitle().trim() === titleHold.trim()) {
          ev.setTitle(titleBooked);
          Logger.log(`Updated calendar event: '${titleHold}' → '${titleBooked}'`);
        }
      }
    }
  } catch(e) {
    followUpWarnings.push("Calendar update failed: " + e);
    Logger.log("Calendar update error: " + e);
  }
  // --- STEP 5: Rename the Google Doc/Sheet for this quote ---
  try {
    const bookingId = String(waitingData["Booking ID"] || "").trim();
    const renterName = String(waitingData["Renter Name"] || "").trim();

    const safeBooking = bookingId.replace(/\s+/g, "");
    const safeName = renterName.replace(/\s+/g, "");

    const oldFileName = `quote-${safeBooking}-${safeName}-RentalAgreement`;
    const newFileName = `${safeBooking}-${safeName}-RentalAgreement`;

    const folder = getQuoteStorageFolderForDate_(waitingData["Start Date"]).yearFolder;
    const files = folder.getFilesByName(oldFileName);

    if (files.hasNext()) {
      const file = files.next();
      file.setName(newFileName);
      Logger.log(`Renamed file '${oldFileName}' → '${newFileName}'`);
    } else {
      Logger.log(`File '${oldFileName}' not found in folder '${folder.getName()}'.`);
    }
  } catch (err) {
    followUpWarnings.push("Quote file rename failed: " + err);
    Logger.log("Error renaming quote file: " + err);
  }

  // STEP 6: Delete the old row from Waiting to Book
  waitingSheet.deleteRow(row);

  const warningMessage = followUpWarnings.length ? `\n\nWarnings:\n- ${followUpWarnings.join("\n- ")}` : "";
  showMessage_(
    "Booking Status",
    `Reservation for ${waitingData["Renter Name"]} has been booked.${warningMessage}`,
    settings
  );
}



