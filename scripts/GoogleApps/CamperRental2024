function insertContactRow_(renterName, renterPhone, renterEmail) {
  if (!renterName) {
    throw new Error("Cannot add contact row: renter name is blank.");
  }

  const contactsSheet = getContactsSheet_();

  const nextCell = findExactCell_(contactsSheet, "{{next}}");
  if (!nextCell) {
    throw new Error(`Cannot find {{next}} placeholder in '${CONTACTS_SHEET_NAME}'.`);
  }

  const headerRow = CONTACTS_HEADER_ROW;
  const headers = contactsSheet.getRange(headerRow, 1, 1, contactsSheet.getLastColumn()).getDisplayValues()[0];
  const nameCol = getColumnIndexByHeaderName_(headers, "Renter Name");
  const phoneCol = getColumnIndexByHeaderName_(headers, "Renter Phone");
  const emailCol = getColumnIndexByHeaderName_(headers, "Renter Email");

  if (!nameCol) {
    throw new Error(`Column 'Renter Name' not found in '${CONTACTS_SHEET_NAME}'.`);
  }

  const duplicateRow = findExistingContactRow_(contactsSheet, headerRow, nextCell.getRow(), {
    renterName,
    renterPhone,
    renterEmail,
    nameCol,
    phoneCol,
    emailCol
  });

  if (duplicateRow) {
    return {
      row: duplicateRow,
      yearAdded: "",
      wasAdded: false
    };
  }

  const insertRow = nextCell.getRow();
  contactsSheet.insertRowBefore(insertRow);

  const currentYear = String(new Date().getFullYear());
  const rowValues = headers.map(header => {
    const cleanHeader = String(header || "").trim();
    if (cleanHeader === "Renter Name") return renterName;
    if (cleanHeader === "Renter Phone") return renterPhone || "";
    if (cleanHeader === "Renter Email") return renterEmail || "";
    if (cleanHeader === "Year Added") return currentYear;
    return "";
  });

  contactsSheet.getRange(insertRow, 1, 1, rowValues.length).setValues([rowValues]);
  contactsSheet.getRange(insertRow, CONTACTS_SELECT_COLUMN).setDataValidation(buildCheckboxRule_()).setValue(false);

  return {
    row: insertRow,
    yearAdded: currentYear,
    wasAdded: true
  };
}

function getColumnIndexByHeaderName_(headers, headerName) {
  for (let i = 0; i < headers.length; i++) {
    if (String(headers[i] || "").trim() === headerName) return i + 1;
  }
  return 0;
}

function findExistingContactRow_(sheet, headerRow, nextRow, contactInfo) {
  const lastDataRow = nextRow - 1;
  if (lastDataRow <= headerRow) return 0;

  const lastCol = sheet.getLastColumn();
  const values = sheet.getRange(headerRow + 1, 1, lastDataRow - headerRow, lastCol).getDisplayValues();
  const normalizedName = normalizeContactValue_(contactInfo.renterName);
  const normalizedPhone = normalizePhoneNumberForMatch_(contactInfo.renterPhone);
  const normalizedEmail = normalizeContactValue_(contactInfo.renterEmail);
  const useNameOnlyMatch = normalizedEmail === "outdoorsy" || normalizedEmail === normalizeContactValue_(HHR_EMAIL_ADDRESS);
  const hasMeaningfulEmail = isMeaningfulContactEmail_(normalizedEmail);
  const hasMeaningfulPhone = normalizedPhone !== "";

  for (let i = 0; i < values.length; i++) {
    const rowValues = values[i];
    const rowName = normalizeContactValue_(rowValues[contactInfo.nameCol - 1]);
    const rowPhone = normalizePhoneNumberForMatch_(contactInfo.phoneCol ? rowValues[contactInfo.phoneCol - 1] : "");
    const rowEmail = normalizeContactValue_(contactInfo.emailCol ? rowValues[contactInfo.emailCol - 1] : "");
    const sameName = normalizedName && rowName && normalizedName === rowName;
    const samePhone = hasMeaningfulPhone && rowPhone && normalizedPhone === rowPhone;
    const sameEmail = hasMeaningfulEmail && rowEmail && normalizedEmail === rowEmail;

    if (useNameOnlyMatch) {
      if (sameName) return headerRow + 1 + i;
      continue;
    }

    if (sameEmail) return headerRow + 1 + i;
    if (samePhone && sameName) return headerRow + 1 + i;
    if (!hasMeaningfulEmail && !hasMeaningfulPhone && sameName) return headerRow + 1 + i;
  }

  return 0;
}

function normalizeContactValue_(value) {
  return normalizeTextValue_(value);
}

function normalizePhoneNumberForMatch_(value) {
  return String(value || "").replace(/\D/g, "");
}

function isMeaningfulContactEmail_(normalizedEmail) {
  if (!normalizedEmail) return false;
  if (normalizedEmail === "outdoorsy" || normalizedEmail === "n/a") return false;
  if (normalizedEmail === normalizeContactValue_(HHR_EMAIL_ADDRESS)) return false;
  return true;
}

