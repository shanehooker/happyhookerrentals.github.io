/**
 * Named range / document template merge helpers for TemplateRentalAgreement-2026.
 */
function getNamedRangeMergeValues_(ss) {
  const values = {};

  ss.getNamedRanges().forEach(namedRange => {
    const name = namedRange.getName();
    const range = namedRange.getRange();
    values[name] = range.getDisplayValue();
  });

  return values;
}

function escapeForReplaceText_(text) {
  return String(text).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function replaceNamedRangePlaceholders_(doc, mergeValues) {
  const body = doc.getBody();
  const header = doc.getHeader();
  const footer = doc.getFooter();

  Object.keys(mergeValues).forEach(name => {
    const placeholder = `<<${name}>>`;
    const escapedPlaceholder = escapeForReplaceText_(placeholder);
    const value = String(mergeValues[name] || "");

    body.replaceText(escapedPlaceholder, value);
    if (header) header.replaceText(escapedPlaceholder, value);
    if (footer) footer.replaceText(escapedPlaceholder, value);
  });
}

function getMergeValue_(mergeValues, possibleNames) {
  for (const name of possibleNames) {
    if (mergeValues[name] !== undefined && String(mergeValues[name]).trim() !== "") {
      return String(mergeValues[name]).trim();
    }
  }
  return "";
}

function parseSheetDate_(value) {
  if (Object.prototype.toString.call(value) === "[object Date]" && !isNaN(value)) {
    return value;
  }

  const parsed = new Date(value);
  return isNaN(parsed.getTime()) ? null : parsed;
}

function addDays_(dateValue, daysToAdd) {
  const parsedDate = parseSheetDate_(dateValue);
  if (!parsedDate) return null;

  const result = new Date(parsedDate.getTime());
  result.setDate(result.getDate() + Number(daysToAdd || 0));
  return result;
}

function formatSheetDate_(dateValue) {
  const parsedDate = parseSheetDate_(dateValue);
  if (!parsedDate) return "";
  return Utilities.formatDate(parsedDate, Session.getScriptTimeZone(), "MM/dd/yyyy");
}

function normalizeSheetDate_(dateValue) {
  const parsedDate = parseSheetDate_(dateValue);
  if (!parsedDate) return null;
  return new Date(parsedDate.getFullYear(), parsedDate.getMonth(), parsedDate.getDate());
}

function getDateKey_(dateValue) {
  const normalizedDate = normalizeSheetDate_(dateValue);
  if (!normalizedDate) return "";
  return Utilities.formatDate(normalizedDate, Session.getScriptTimeZone(), "yyyy-MM-dd");
}

function getDateRangeDayKeys_(startDateValue, endDateValue) {
  const startDate = normalizeSheetDate_(startDateValue);
  const endDate = normalizeSheetDate_(endDateValue);
  if (!startDate || !endDate || endDate < startDate) return [];

  const dayKeys = [];
  for (let d = new Date(startDate.getTime()); d <= endDate; d.setDate(d.getDate() + 1)) {
    dayKeys.push(getDateKey_(d));
  }

  return dayKeys;
}

function doDateRangesOverlap_(firstStartDate, firstEndDate, secondStartDate, secondEndDate) {
  const firstRangeDayKeys = getDateRangeDayKeys_(firstStartDate, firstEndDate);
  const secondRangeDayKeys = getDateRangeDayKeys_(secondStartDate, secondEndDate);
  if (!firstRangeDayKeys.length || !secondRangeDayKeys.length) return false;

  const secondRangeLookup = {};
  secondRangeDayKeys.forEach(dayKey => {
    secondRangeLookup[dayKey] = true;
  });

  return firstRangeDayKeys.some(dayKey => secondRangeLookup[dayKey]);
}

function isSameSheetDate_(firstDateValue, secondDateValue) {
  const firstDateKey = getDateKey_(firstDateValue);
  const secondDateKey = getDateKey_(secondDateValue);
  return firstDateKey !== "" && firstDateKey === secondDateKey;
}

function isBackToBackBooking_(quoteStartDate, quoteEndDate, existingStartDate, existingEndDate) {
  return isSameSheetDate_(quoteStartDate, existingEndDate) || isSameSheetDate_(quoteEndDate, existingStartDate);
}

function normalizeTextValue_(value) {
  return String(value || "").trim().toLowerCase();
}

function buildQuoteConflictMessage_(severity, conflictType, sheetName, rowNumber, rowData, bookingKind) {
  const camper = String(rowData["Camper"] || "").trim();
  const renterName = String(rowData["Renter Name"] || "").trim() || "unknown renter";
  const startDate = formatSheetDate_(rowData["Start Date"]) || String(rowData["Start Date"] || "").trim();
  const endDate = formatSheetDate_(rowData["End Date"]) || String(rowData["End Date"] || "").trim();

  return `${severity}: ${conflictType} with ${bookingKind} in '${sheetName}' row ${rowNumber} for camper '${camper}' (${startDate} - ${endDate}, ${renterName}).`;
}

function getSheetRowsByHeaders_(sheet, headerRow) {
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow <= headerRow || lastCol < 1) return [];

  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getDisplayValues()[0];
  const values = sheet.getRange(headerRow + 1, 1, lastRow - headerRow, lastCol).getDisplayValues();

  return values.map((rowValues, index) => {
    const data = {};
    headers.forEach((header, headerIndex) => {
      if (header) data[String(header).trim()] = rowValues[headerIndex];
    });

    return {
      rowNumber: headerRow + 1 + index,
      data: data
    };
  });
}

function validateBookingConflictHeaders_(sheet, headerRow) {
  const requiredHeaders = ["Camper", "Start Date", "End Date"];
  const missingHeaders = requiredHeaders.filter(headerName => !getColumnByHeader_(sheet, headerRow, headerName));
  if (!missingHeaders.length) return;

  throw new Error(`Sheet '${sheet.getName()}' is missing required header(s): ${missingHeaders.join(", ")}.`);
}

function getQuoteConflicts_(workflowSpreadsheet, quoteContext) {
  const bookingsSheet = workflowSpreadsheet.getSheetByName(BOOKINGS_SHEET_NAME);
  const waitingSheet = workflowSpreadsheet.getSheetByName(WAITING_SHEET_NAME);

  if (!bookingsSheet) {
    throw new Error(`Sheet '${BOOKINGS_SHEET_NAME}' not found in '${workflowSpreadsheet.getName()}'.`);
  }
  if (!waitingSheet) {
    throw new Error(`Sheet '${WAITING_SHEET_NAME}' not found in '${workflowSpreadsheet.getName()}'.`);
  }

  validateBookingConflictHeaders_(bookingsSheet, BOOKINGS_HEADER_ROW);
  validateBookingConflictHeaders_(waitingSheet, WAITING_HEADER_ROW);

  const conflicts = {
    errors: [],
    warnings: []
  };

  function scanSheet_(sheet, headerRow, bookingKind, bookingConflictSeverity) {
    const rows = getSheetRowsByHeaders_(sheet, headerRow);

    rows.forEach(row => {
      const rowData = row.data;
      const camper = String(rowData["Camper"] || "").trim();
      const startDate = parseSheetDate_(rowData["Start Date"]);
      const endDate = parseSheetDate_(rowData["End Date"]);

      if (!camper || !startDate || !endDate) return;

      const sameCamper = normalizeTextValue_(camper) === normalizeTextValue_(quoteContext.camper);
      const isBackToBack = sameCamper && isBackToBackBooking_(quoteContext.startDate, quoteContext.endDate, startDate, endDate);

      if (isBackToBack) {
        conflicts.warnings.push(
          buildQuoteConflictMessage_(
            "warning",
            "back-to-back booking",
            sheet.getName(),
            row.rowNumber,
            rowData,
            bookingKind
          )
        );
      } else if (sameCamper && doDateRangesOverlap_(quoteContext.startDate, quoteContext.endDate, startDate, endDate)) {
        const bookingConflictMessage = buildQuoteConflictMessage_(
          bookingConflictSeverity,
          "booking conflict",
          sheet.getName(),
          row.rowNumber,
          rowData,
          bookingKind
        );

        if (bookingConflictSeverity === "error") {
          conflicts.errors.push(bookingConflictMessage);
        } else {
          conflicts.warnings.push(bookingConflictMessage);
        }
      }

      const hasDeliveryConflict =
        isSameSheetDate_(startDate, quoteContext.startDate) ||
        isSameSheetDate_(startDate, quoteContext.endDate) ||
        isSameSheetDate_(endDate, quoteContext.startDate) ||
        isSameSheetDate_(endDate, quoteContext.endDate);

      if (hasDeliveryConflict) {
        conflicts.warnings.push(
          buildQuoteConflictMessage_(
            "warning",
            "delivery conflict",
            sheet.getName(),
            row.rowNumber,
            rowData,
            bookingKind
          )
        );
      }
    });
  }

  scanSheet_(bookingsSheet, BOOKINGS_HEADER_ROW, "confirmed booking", "error");
  scanSheet_(waitingSheet, WAITING_HEADER_ROW, "potential booking", "warning");

  return conflicts;
}

