function getWorkflowSearchFolders_() {
  const rootFolder = getQuoteRootFolder_();
  const folders = [rootFolder];
  const parents = rootFolder.getParents();

  if (parents.hasNext()) {
    const parentFolder = parents.next();
    if (parentFolder.getId() !== rootFolder.getId()) {
      folders.push(parentFolder);
    }
  }

  return folders;
}

function getFolderSearchChain_(folder) {
  const folders = [];
  const seen = {};
  let currentFolder = folder;

  while (currentFolder) {
    const folderId = currentFolder.getId();
    if (seen[folderId]) break;

    seen[folderId] = true;
    folders.push(currentFolder);

    const parents = currentFolder.getParents();
    currentFolder = parents.hasNext() ? parents.next() : null;
  }

  return folders;
}

function findGoogleSheetByNamesInFolder_(folder, possibleNames) {
  for (const fileName of possibleNames) {
    const matchingFiles = folder.getFilesByName(fileName);
    let matchedFile = null;
    let matchCount = 0;

    while (matchingFiles.hasNext()) {
      const file = matchingFiles.next();
      if (file.getMimeType() !== MimeType.GOOGLE_SHEETS) continue;

      if (!matchedFile) matchedFile = file;
      matchCount++;
    }

    if (!matchedFile) continue;

    if (matchCount > 1) {
      Logger.log(`WARNING - Multiple Google Sheets named '${fileName}' found in '${folder.getName()}'. Using the first match.`);
    }

    return {
      file: matchedFile,
      matchedName: fileName,
      folder: folder
    };
  }

  return null;
}

function isWorkflowSpreadsheetName_(fileName) {
  return /^HHRentals-?\d{4}-?IncomeExpenses$/.test(String(fileName || "").trim());
}

function getAllWorkflowSpreadsheets_() {
  const spreadsheets = [];
  const seenFileIds = {};
  const folders = getWorkflowSearchFolders_();

  for (const folder of folders) {
    const files = folder.getFiles();

    while (files.hasNext()) {
      const file = files.next();
      const fileId = file.getId();

      if (seenFileIds[fileId]) continue;
      if (file.getMimeType() !== MimeType.GOOGLE_SHEETS) continue;
      if (!isWorkflowSpreadsheetName_(file.getName())) continue;

      seenFileIds[fileId] = true;
      spreadsheets.push(SpreadsheetApp.openById(fileId));
    }
  }

  return spreadsheets;
}

function getRentalAgreementSearchFolders_(startDateValue) {
  const folders = [];
  const seenFolderIds = {};

  function addFolder_(folder) {
    if (!folder) return;

    const folderId = folder.getId();
    if (seenFolderIds[folderId]) return;

    seenFolderIds[folderId] = true;
    folders.push(folder);
  }

  try {
    addFolder_(getQuoteStorageFolderForDate_(startDateValue).yearFolder);
  } catch (e) {
    Logger.log(`Could not derive year folder from start date '${startDateValue}': ${e}`);
  }

  const configuredFolder = getConfiguredQuoteFolder_();
  const rootFolder = getQuoteRootFolder_();

  addFolder_(configuredFolder);
  addFolder_(rootFolder);

  const rootSubfolders = rootFolder.getFolders();
  while (rootSubfolders.hasNext()) {
    const folder = rootSubfolders.next();
    if (!/^\d{4}$/.test(String(folder.getName() || "").trim())) continue;
    addFolder_(folder);
  }

  return folders;
}

function getQuoteStorageFolderForDate_(dateValue) {
  const bookingDate = parseSheetDate_(dateValue);
  if (!bookingDate) {
    throw new Error(`Cannot determine quote storage folder because the booking start date '${dateValue}' is invalid.`);
  }

  const bookingYear = bookingDate.getFullYear();
  const rootFolder = getQuoteRootFolder_();
  const folderName = getYearFolderName_(bookingYear);
  const matchingFolders = rootFolder.getFoldersByName(folderName);

  if (!matchingFolders.hasNext()) {
    throw new Error(
      `Missing required year folder '${folderName}' under '${rootFolder.getName()}'. ` +
      `Create a new sheet and folder for ${folderName} before creating quotes for that year.`
    );
  }

  const yearFolder = matchingFolders.next();
  if (matchingFolders.hasNext()) {
    Logger.log(`WARNING - Multiple year folders named '${folderName}' found in '${rootFolder.getName()}'. Using the first match.`);
  }

  return {
    year: bookingYear,
    rootFolder: rootFolder,
    yearFolder: yearFolder
  };
}

function getWorkflowSpreadsheetForYear_(year) {
  const rootFolder = getQuoteRootFolder_();
  const possibleNames = getIncomeExpensesSpreadsheetNamesForYear_(year);
  const folderSearchChain = getWorkflowSearchFolders_();

  for (const folder of folderSearchChain) {
    const match = findGoogleSheetByNamesInFolder_(folder, possibleNames);
    if (match) {
      Logger.log(
        `Using workflow spreadsheet '${match.matchedName}' from folder '${match.folder.getName()}' for ${year}.`
      );
      return SpreadsheetApp.openById(match.file.getId());
    }
  }

  throw new Error(
    `Missing required spreadsheet for ${year}. Expected one of: ${possibleNames.join(", ")} ` +
    `under '${rootFolder.getName()}' or one of its parent folders. Create the yearly sheet before creating quotes for that year.`
  );
}

function getQuoteWorkflowContext_(startDateValue) {
  const bookingDate = parseSheetDate_(startDateValue);
  if (!bookingDate) {
    throw new Error(`Cannot determine workflow year because the booking start date '${startDateValue}' is invalid.`);
  }

  const folderContext = getQuoteStorageFolderForDate_(bookingDate);
  const workflowSpreadsheet = getWorkflowSpreadsheetForYear_(folderContext.year);

  return {
    bookingDate: bookingDate,
    year: folderContext.year,
    rootFolder: folderContext.rootFolder,
    yearFolder: folderContext.yearFolder,
    spreadsheet: workflowSpreadsheet
  };
}

